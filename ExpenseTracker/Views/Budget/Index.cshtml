@model IEnumerable<ExpenseTracker.Models.Entities.Budget>

@{
    ViewData["Title"] = "Monthly Budgets";
    var months = System.Globalization.DateTimeFormatInfo.InvariantInfo.MonthNames;
}

<style>
    :root {
        --accent: #6366f1;
        --accent-soft: rgba(99, 102, 241, 0.1);
        --card-radius: 24px;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
    }

    .budget-page-wrapper {
        animation: fadeIn 0.5s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .premium-card {
        background: var(--card);
        border-radius: var(--card-radius);
        border: 1px solid rgba(0,0,0,0.03);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        margin-bottom: 24px;
    }

    .budget-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 24px;
    }

    .budget-card {
        background: var(--card);
        border-radius: 24px;
        padding: 24px;
        border: 1px solid rgba(0,0,0,0.03);
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        transition: all 0.3s ease;
    }

    .budget-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
    }

    .budget-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
    }

    .category-info h6 {
        font-weight: 800;
        margin: 0;
        color: var(--text-main);
    }

    .period-badge {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        background: var(--accent-soft);
        color: var(--accent);
        padding: 4px 12px;
        border-radius: 20px;
    }

    .progress-section {
        margin-bottom: 15px;
    }

    .progress-meta {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
        font-size: 0.85rem;
    }

    .amount-spent { font-weight: 700; color: var(--text-main); }
    .amount-total { color: var(--muted); }

    .progress-bar-container {
        height: 10px;
        background: var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        border-radius: 10px;
        transition: width 1s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .status-text {
        font-size: 0.75rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .action-links {
        display: flex;
        gap: 10px;
        margin-top: 20px;
        padding-top: 15px;
        border-top: 1px solid #f1f5f9;
    }

    .btn-budget-action {
        flex: 1;
        padding: 8px;
        border-radius: 10px;
        font-size: 0.8rem;
        font-weight: 700;
        text-align: center;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-edit-budget { background: var(--bg); color: var(--muted); border: 1px solid var(--border); }
    .btn-edit-budget:hover { background: var(--accent-soft); color: var(--accent); border-color: var(--accent); }

    .btn-delete-budget { background: #fff5f5; color: #ef4444; border: 1px solid #fee2e2; }
    .btn-delete-budget:hover { background: #ef4444; color: white; }
</style>

<div class="budget-page-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
        <div>
            <h1 class="h3 fw-800 text-main-adaptive m-0">Budget Planning</h1>
            <p class="text-muted small m-0">Set limits for your categories and stay on track with your savings.</p>
        </div>
        <a asp-action="Create" class="btn btn-indigo rounded-pill px-4 py-2 fw-bold shadow-sm" style="background: var(--accent); color: white">
            <i data-lucide="plus-circle" class="me-2" style="width: 18px"></i> Create Budget
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="premium-card p-5 text-center">
            <div class="mb-3">
                <i data-lucide="target" style="width: 60px; height: 60px; color: #cbd5e1"></i>
            </div>
            <h4 class="fw-800 text-main-adaptive">No Budgets Found</h4>
            <p class="text-muted">You haven't set any budgets for @DateTime.Now.Year yet. Take control of your spending now!</p>
            <a asp-action="Create" class="btn btn-indigo rounded-pill px-4 mt-3" style="background: var(--accent); color: white">Get Started</a>
        </div>
    }
    else
    {
        <div class="budget-grid">
            @foreach (var budget in Model)
            {
                var actual = (decimal)(ViewData[$"Actual_{budget.Id}"] ?? 0m);
                var percent = budget.Amount > 0 ? (actual / budget.Amount * 100) : 0;
                var remaining = budget.Amount - actual;
                
                var barColor = "var(--success)";
                var statusText = "On Track";
                var statusIcon = "check-circle";
                var statusClass = "text-success";

                if (percent >= 100) { barColor = "var(--danger)"; statusText = "Over Budget"; statusIcon = "alert-octagon"; statusClass = "text-danger"; }
                else if (percent >= 80) { barColor = "var(--warning)"; statusText = "Near Limit"; statusIcon = "alert-triangle"; statusClass = "text-warning"; }

                <div class="budget-card">
                    <div class="budget-header">
                        <div class="category-info">
                            <span class="period-badge">@months[budget.Month - 1] @budget.Year</span>
                            <h6 class="mt-2">@(budget.Category?.Name ?? "General")</h6>
                        </div>
                        <div class="status-text @statusClass">
                            <i data-lucide="@statusIcon" style="width: 14px"></i>
                            @statusText
                        </div>
                    </div>

                    <div class="progress-section">
                        <div class="progress-meta">
                            <span class="amount-spent">₹ @actual.ToString("N0")</span>
                            <span class="amount-total">of ₹ @budget.Amount.ToString("N0")</span>
                        </div>
                        <div class="progress-bar-container">
                            <div class="progress-bar-fill" style="width: @(Math.Min(percent, 100))%; background: @barColor;"></div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted small">
                            @if (remaining >= 0) { <span>₹ @remaining.ToString("N0") left</span> }
                            else { <span>₹ @Math.Abs(remaining).ToString("N0") over</span> }
                        </span>
                        <span class="fw-bold @statusClass" style="font-size: 0.8rem">@percent.ToString("N0")%</span>
                    </div>

                    <div class="action-links">
                        <a asp-action="Edit" asp-route-id="@budget.Id" class="btn-budget-action btn-edit-budget">
                            <i data-lucide="pencil" style="width: 14px" class="me-1"></i> Adjust
                        </a>
                        <a href="#" class="btn-budget-action btn-delete-budget btn-delete-budget-trigger" data-id="@budget.Id">
                            <i data-lucide="trash-2" style="width: 14px" class="me-1"></i> Remove
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteBudgetModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-custom-content">
            <div class="modal-header modal-custom-header">
                <div class="mb-3">
                    <div class="icon-box bg-danger-subtle text-danger p-3 rounded-circle d-inline-flex">
                        <i data-lucide="trash-2" size="32"></i>
                    </div>
                </div>
                <h4 class="fw-800 text-main-adaptive mb-0">Delete Budget</h4>
            </div>
            <div class="modal-body modal-custom-body">
                Are you sure you want to delete this budget? This action cannot be undone.
            </div>
            <div class="modal-footer modal-custom-footer">
                <button type="button" class="btn-modal-cancel flex-grow-1" data-bs-dismiss="modal">Cancel</button>
                <a id="confirmDeleteBudgetBtn" href="#" class="btn-modal-confirm flex-grow-1 text-decoration-none text-center">Delete</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            lucide.createIcons();

            $('.btn-delete-budget-trigger').on('click', function(e) {
                e.preventDefault();
                const budgetId = $(this).data('id');
                const deleteUrl = `/Budget/Delete/${budgetId}`;
                $('#confirmDeleteBudgetBtn').attr('href', deleteUrl);
                const modal = new bootstrap.Modal(document.getElementById('deleteBudgetModal'));
                modal.show();
            });
        });
    </script>
}

