@model IEnumerable<ExpenseTracker.Models.Entities.Budget>

@{
    ViewData["Title"] = "Monthly Budgets";
    var months = System.Globalization.DateTimeFormatInfo.InvariantInfo.MonthNames;
}

<style>
    :root { --accent:#0ea5e9; --accent-hover:#0284c7; --accent-soft:rgba(14,165,233,0.08); --success:#10b981; --success-soft:rgba(16,185,129,0.08); --warning:#f59e0b; --warning-soft:rgba(245,158,11,0.08); --danger:#ef4444; --danger-soft:rgba(239,68,68,0.08); }
    .bud-page { animation:pageIn 0.45s ease-out; }
    @@keyframes pageIn { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
    @@keyframes cardIn { from{opacity:0;transform:translateY(10px) scale(0.98)} to{opacity:1;transform:translateY(0) scale(1)} }

    .bud-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; gap:16px; flex-wrap:wrap; }
    .bud-header h1 { font-size:1.35rem; font-weight:800; color:var(--text-main); margin:0; }
    .bud-header p { font-size:0.84rem; color:var(--muted); margin:4px 0 0; }
    .btn-add { display:inline-flex; align-items:center; gap:8px; background:var(--accent); color:white; border:none; padding:11px 24px; border-radius:12px; font-weight:700; font-size:0.88rem; text-decoration:none; transition:all 0.22s; box-shadow:0 4px 16px rgba(14,165,233,0.2); }
    .btn-add:hover { background:var(--accent-hover); transform:translateY(-1px); box-shadow:0 8px 24px rgba(14,165,233,0.3); color:white; }

    .bud-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(300px,1fr)); gap:16px; }

    /* Budget Card */
    .bud-card { background:var(--card); border:1px solid var(--border); border-radius:18px; padding:22px 24px; transition:all 0.25s; animation:cardIn 0.35s ease-out both; }
    .bud-card:hover { transform:translateY(-3px); box-shadow:0 10px 28px rgba(0,0,0,0.07); }
    .bud-card:nth-child(1){animation-delay:.03s} .bud-card:nth-child(2){animation-delay:.06s} .bud-card:nth-child(3){animation-delay:.09s}
    .bud-card:nth-child(4){animation-delay:.12s} .bud-card:nth-child(5){animation-delay:.15s} .bud-card:nth-child(6){animation-delay:.18s}

    .bud-card-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:18px; }
    .bud-cat-name { font-size:1rem; font-weight:800; color:var(--text-main); margin:0; }
    .bud-period { font-size:0.68rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; padding:3px 10px; border-radius:8px; background:var(--accent-soft); color:var(--accent); margin-bottom:6px; display:inline-block; }

    .bud-status-chip { display:inline-flex; align-items:center; gap:4px; font-size:0.7rem; font-weight:700; padding:4px 10px; border-radius:8px; }
    .bud-status-chip.good { background:var(--success-soft); color:var(--success); }
    .bud-status-chip.warn { background:var(--warning-soft); color:var(--warning); }
    .bud-status-chip.over { background:var(--danger-soft); color:var(--danger); }
    [data-theme="dark"] .bud-status-chip.good { background:rgba(34,197,94,0.15); color:#4ade80; }
    [data-theme="dark"] .bud-status-chip.warn { background:rgba(245,158,11,0.15); color:#fbbf24; }
    [data-theme="dark"] .bud-status-chip.over { background:rgba(239,68,68,0.15); color:#f87171; }

    /* Progress */
    .bud-progress { margin-bottom:14px; }
    .bud-progress-meta { display:flex; justify-content:space-between; margin-bottom:8px; }
    .bud-spent { font-size:0.88rem; font-weight:700; color:var(--text-main); }
    .bud-total { font-size:0.82rem; font-weight:600; color:var(--muted); }
    .bud-track { height:8px; background:var(--bg); border-radius:8px; overflow:hidden; }
    .bud-fill { height:100%; border-radius:8px; transition:width 1s cubic-bezier(0.17,0.67,0.83,0.67); }

    .bud-footer { display:flex; justify-content:space-between; align-items:center; padding-top:14px; border-top:1px solid var(--border); }
    .bud-remaining { font-size:0.8rem; font-weight:600; color:var(--muted); }
    .bud-pct { font-size:0.78rem; font-weight:800; }

    /* Action buttons */
    .bud-actions { display:flex; gap:8px; }
    .bud-act-btn { flex:1; padding:9px 12px; border-radius:10px; font-size:0.78rem; font-weight:700; text-align:center; text-decoration:none; transition:all 0.2s; display:inline-flex; align-items:center; justify-content:center; gap:5px; }
    .bud-act-btn.edit { background:var(--bg); color:var(--muted); border:1px solid var(--border); }
    .bud-act-btn.edit:hover { background:var(--accent-soft); color:var(--accent); border-color:rgba(14,165,233,0.25); }
    .bud-act-btn.delete { background:var(--danger-soft); color:var(--danger); border:1px solid transparent; }
    .bud-act-btn.delete:hover { background:var(--danger); color:white; }

    /* Empty */
    .empty-card { grid-column:1/-1; text-align:center; padding:56px 24px; background:var(--card); border:1px dashed var(--border); border-radius:20px; }
    .empty-icon { width:72px; height:72px; border-radius:20px; background:var(--accent-soft); color:var(--accent); display:flex; align-items:center; justify-content:center; margin:0 auto 18px; }
    .empty-card h5 { font-size:1.1rem; font-weight:800; color:var(--text-main); margin:0 0 6px; }
    .empty-card p { font-size:0.84rem; color:var(--muted); margin:0 0 20px; max-width:340px; margin-left:auto; margin-right:auto; }

    /* Modal */
    .del-modal .modal-content { border-radius:24px; border:none; box-shadow:0 30px 80px rgba(0,0,0,0.18); background:var(--card); }
    .del-modal-icon { width:68px; height:68px; border-radius:50%; background:var(--danger-soft); color:var(--danger); display:flex; align-items:center; justify-content:center; margin:0 auto 18px; }
    .modal-btn-del { background:var(--danger); color:white; border:none; padding:12px 28px; border-radius:12px; font-weight:700; transition:all 0.2s; text-decoration:none; }
    .modal-btn-del:hover { background:#dc2626; transform:translateY(-1px); box-shadow:0 8px 20px rgba(239,68,68,0.25); color:white; }
    .modal-btn-cancel { background:var(--bg); color:var(--muted); border:1px solid var(--border); padding:12px 28px; border-radius:12px; font-weight:700; transition:all 0.2s; }
    .modal-btn-cancel:hover { background:var(--border); color:var(--text-main); }

    @@media (max-width:767.98px) {
        .bud-header { flex-direction:column; align-items:stretch; margin-bottom:18px; }
        .bud-header h1 { font-size:1.2rem; }
        .btn-add { justify-content:center; padding:13px 20px; }
        .bud-grid { grid-template-columns:1fr; gap:12px; }
        .bud-card { padding:18px 16px; border-radius:16px; }
        .bud-cat-name { font-size:0.92rem; }
        .empty-card { padding:40px 16px; }
    }
</style>

<div class="bud-page">
    <div class="bud-header">
        <div>
            <h1>Budget Planning</h1>
            <p>Set limits for your categories and stay on track with savings.</p>
        </div>
        <a asp-action="Create" class="btn-add"><i data-lucide="plus-circle" style="width:18px;height:18px"></i> Create Budget</a>
    </div>

    <div class="bud-grid">
        @if (!Model.Any())
        {
            <div class="empty-card">
                <div class="empty-icon"><i data-lucide="target" style="width:28px;height:28px"></i></div>
                <h5>No Budgets Found</h5>
                <p>You haven't set any budgets for @DateTime.Now.Year yet. Take control of your spending now!</p>
                <a asp-action="Create" class="btn-add"><i data-lucide="plus-circle" style="width:18px;height:18px"></i> Get Started</a>
            </div>
        }
        else
        {
            foreach (var budget in Model)
            {
                var actual = (decimal)(ViewData[$"Actual_{budget.Id}"] ?? 0m);
                var percent = budget.Amount > 0 ? (actual / budget.Amount * 100) : 0;
                var remaining = budget.Amount - actual;

                var barColor = "var(--success)";
                var statusText = "On Track"; var statusIcon = "check-circle"; var statusClass = "good";
                if (percent >= 100) { barColor = "var(--danger)"; statusText = "Over Budget"; statusIcon = "alert-octagon"; statusClass = "over"; }
                else if (percent >= 80) { barColor = "var(--warning)"; statusText = "Near Limit"; statusIcon = "alert-triangle"; statusClass = "warn"; }

                <div class="bud-card">
                    <div class="bud-card-top">
                        <div>
                            <span class="bud-period">@months[budget.Month - 1] @budget.Year</span>
                            <h6 class="bud-cat-name">@(budget.Category?.Name ?? "General")</h6>
                        </div>
                        <span class="bud-status-chip @statusClass">
                            <i data-lucide="@statusIcon" style="width:12px;height:12px"></i> @statusText
                        </span>
                    </div>

                    <div class="bud-progress">
                        <div class="bud-progress-meta">
                            <span class="bud-spent">₹@actual.ToString("N2")</span>
                            <span class="bud-total">of ₹@budget.Amount.ToString("N2")</span>
                        </div>
                        <div class="bud-track">
                            <div class="bud-fill" style="width:@(Math.Min(percent, 100))%;background:@barColor"></div>
                        </div>
                    </div>

                    <div class="bud-footer">
                        <span class="bud-remaining">
                            @if (remaining >= 0) { <span>₹@remaining.ToString("N2") left</span> }
                            else { <span style="color:var(--danger)">₹@Math.Abs(remaining).ToString("N2") over</span> }
                        </span>
                        <span class="bud-pct" style="color:@barColor">@percent.ToString("N0")%</span>
                    </div>

                    <div class="bud-actions" style="margin-top:14px">
                        <a asp-action="Edit" asp-route-id="@budget.Id" class="bud-act-btn edit">
                            <i data-lucide="pencil" style="width:13px;height:13px"></i> Adjust
                        </a>
                        <a href="#" class="bud-act-btn delete btn-delete-budget-trigger" data-id="@budget.Id">
                            <i data-lucide="trash-2" style="width:13px;height:13px"></i> Remove
                        </a>
                    </div>
                </div>
            }
        }
    </div>
</div>

<div class="modal fade del-modal" id="deleteBudgetModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px">
        <div class="modal-content">
            <div class="modal-body p-5 text-center">
                <div class="del-modal-icon"><i data-lucide="trash-2" style="width:28px;height:28px"></i></div>
                <h4 class="fw-800 text-main-adaptive mb-2" style="font-size:1.15rem">Delete Budget?</h4>
                <p class="text-muted mb-4" style="font-size:0.88rem">This action cannot be undone.</p>
                <div class="d-flex gap-3 justify-content-center">
                    <button type="button" class="modal-btn-cancel flex-grow-1" data-bs-dismiss="modal">Cancel</button>
                    <a id="confirmDeleteBudgetBtn" href="#" class="modal-btn-del flex-grow-1 text-decoration-none text-center">Delete</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            lucide.createIcons();
            $('.btn-delete-budget-trigger').on('click', function(e) {
                e.preventDefault();
                $('#confirmDeleteBudgetBtn').attr('href', `/Budget/Delete/${$(this).data('id')}`);
                new bootstrap.Modal(document.getElementById('deleteBudgetModal')).show();
            });
        });
    </script>
}
