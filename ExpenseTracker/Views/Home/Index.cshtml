                            <div class="budget-bar-shell">
                                <div class="budget-bar-fill" style="background: var(--brand-b); width: 92%;"></div>
                            </div>
                            <div class="budget-val">
                                $1,104.00 <span>/ $1,200.00</span>
                            </div>
                        </div>
                        <div class="budget-row">
                            <div class="budget-info">
                                <h6>🍿 Hobbies & Entertainment</h6>
                                <p>Discretionary spending limit</p>
                            </div>
                            <div class="budget-bar-shell">
                                <div class="budget-bar-fill" style="background: var(--danger); width: 45%;"></div>
                            </div>
                            <div class="budget-val">
                                $180.00 <span>/ $400.00</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tab: Analytics -->
                <div id="view-analytics" class="dashboard-view">
                    <div class="analytics-wrap">
                        <div class="chart-card">
                            <h5 style="font-size: 0.9rem; font-weight: 800; margin-bottom: 12px;">Cashflow Trend</h5>
                            <div style="display: flex; align-items: flex-end; justify-content: space-between; height: 180px; padding-top: 10px;">
                                <div style="display: flex; flex-direction: column; align-items: center; gap: 8px; width: 12%;">
                                    <div style="height: 100px; width: 100%; background: var(--bg-soft); border-radius: 6px; display: flex; align-items: flex-end;">
                                        <div style="height: 60%; width: 100%; background: var(--brand-a); border-radius: 6px;"></div>
                                    </div>
                                    <span style="font-size: 0.65rem; font-weight: 700; color: var(--text-muted);">Jan</span>
                                </div>
                                <div style="display: flex; flex-direction: column; align-items: center; gap: 8px; width: 12%;">
                                    <div style="height: 100px; width: 100%; background: var(--bg-soft); border-radius: 6px; display: flex; align-items: flex-end;">
                                        <div style="height: 75%; width: 100%; background: var(--brand-a); border-radius: 6px;"></div>
                                    </div>
                                    <span style="font-size: 0.65rem; font-weight: 700; color: var(--text-muted);">Feb</span>
                                </div>
                                <div style="display: flex; flex-direction: column; align-items: center; gap: 8px; width: 12%;">
                                    <div style="height: 100px; width: 100%; background: var(--bg-soft); border-radius: 6px; display: flex; align-items: flex-end;">
                                        <div style="height: 40%; width: 100%; background: var(--brand-a); border-radius: 6px;"></div>
                                    </div>
                                    <span style="font-size: 0.65rem; font-weight: 700; color: var(--text-muted);">Mar</span>
                                </div>
                                <div style="display: flex; flex-direction: column; align-items: center; gap: 8px; width: 12%;">
                                    <div style="height: 100px; width: 100%; background: var(--bg-soft); border-radius: 6px; display: flex; align-items: flex-end;">
                                        <div style="height: 90%; width: 100%; background: var(--brand-a); border-radius: 6px;"></div>
                                    </div>
                                    <span style="font-size: 0.65rem; font-weight: 700; color: var(--text-muted);">Apr</span>
                                </div>
                                <div style="display: flex; flex-direction: column; align-items: center; gap: 8px; width: 12%;">
                                    <div style="height: 100px; width: 100%; background: var(--bg-soft); border-radius: 6px; display: flex; align-items: flex-end;">
                                        <div style="height: 85%; width: 100%; background: var(--brand-b); border-radius: 6px;"></div>
                                    </div>
                                    <span style="font-size: 0.65rem; font-weight: 700; color: var(--text-muted);">May</span>
                                </div>
                            </div>
                        </div>
