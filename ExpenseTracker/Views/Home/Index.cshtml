    <!-- Javascript Controls -->
    <script>
        // Init Lucide
        lucide.createIcons();

        // Sticky Header scroll script
        window.addEventListener('scroll', function () {
            const header = document.getElementById('mainHeader');
            if (window.scrollY > 20) {
                header.classList.add('scrolled');
            } else {
                header.classList.remove('scrolled');
            }
        });

        // Theme Toggle Logic
        (function () {
            const html = document.documentElement;
            const toggleBtn = document.getElementById('themeToggle');
            const glyph = document.getElementById('themeGlyph');

            const applyTheme = (theme) => {
                if (theme === 'dark') {
                    html.setAttribute('data-theme', 'dark');
                    html.setAttribute('data-bs-theme', 'dark');
                    glyph.innerHTML = '<i data-lucide="sun" style="width: 18px; height: 18px;"></i>';
                } else {
                    html.removeAttribute('data-theme');
                    html.setAttribute('data-bs-theme', 'light');
                    glyph.innerHTML = '<i data-lucide="moon" style="width: 18px; height: 18px;"></i>';
                }
                localStorage.setItem('theme', theme);
                lucide.createIcons(); // Refresh dynamic icon injection
            };

            const savedTheme = localStorage.getItem('theme') || 'light';
            applyTheme(savedTheme);

            toggleBtn.addEventListener('click', function () {
                const currentTheme = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
                applyTheme(currentTheme);
            });
        })();

        // Mock Dashboard Tab Switching
        function switchTab(tabId) {
            // Deactivate all tabs & views
            document.querySelectorAll('.dashboard-tab').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.dashboard-view').forEach(view => view.classList.remove('active'));

            // Activate select tab
            const activeBtn = Array.from(document.querySelectorAll('.dashboard-tab')).find(btn => btn.textContent.toLowerCase().includes(tabId));
            if (activeBtn) activeBtn.classList.add('active');

            const targetView = document.getElementById('view-' + tabId);
            if (targetView) targetView.classList.add('active');

            // Trigger animation elements specifically
            if (tabId === 'budgets') {
                document.querySelectorAll('.budget-bar-fill').forEach(bar => {
                    const originalWidth = bar.style.width;
                    bar.style.width = '0%';
                    setTimeout(() => {
                        bar.style.width = originalWidth;
                    }, 50);
                });
            }
        }

        // Budget Simulator Calculations & SVG Donut Animating
        const incomeSlider = document.getElementById('incomeSlider');
        const incomeLabel = document.getElementById('incomeLabel');
        const donutTotal = document.getElementById('donutTotal');
        
        const valNeeds = document.getElementById('valNeeds');
        const valWants = document.getElementById('valWants');
        const valSavings = document.getElementById('valSavings');

        const donutNeeds = document.getElementById('donutNeeds');
        const donutWants = document.getElementById('donutWants');
        const donutSavings = document.getElementById('donutSavings');

        function updateBudgetSimulator(incomeVal) {
            const val = parseInt(incomeVal);
            
            // Format labels
            incomeLabel.textContent = '$' + val.toLocaleString();
            donutTotal.textContent = '$' + val.toLocaleString();

            // Calculate splits (50 / 30 / 20)
            const needs = val * 0.5;
            const wants = val * 0.3;
            const savings = val * 0.2;

            valNeeds.textContent = '$' + needs.toLocaleString();
            valWants.textContent = '$' + wants.toLocaleString();
            valSavings.textContent = '$' + savings.toLocaleString();

            // Circular Dash Math
            // Circumference of r=45 circle is 2 * pi * 45 = 282.74
            const circ = 282.74;

            // Wedge lengths
            const lenNeeds = circ * 0.5;
            const lenWants = circ * 0.3;
            const lenSavings = circ * 0.2;

            // Set stroke dash arrays
            donutNeeds.setAttribute('stroke-dasharray', `${lenNeeds} ${circ}`);
            donutWants.setAttribute('stroke-dasharray', `${lenWants} ${circ}`);
            donutSavings.setAttribute('stroke-dasharray', `${lenSavings} ${circ}`);

            // Offset settings
            donutNeeds.setAttribute('stroke-dashoffset', '0');
            donutWants.setAttribute('stroke-dashoffset', `-${lenNeeds}`);
            donutSavings.setAttribute('stroke-dashoffset', `-${lenNeeds + lenWants}`);
        }

        incomeSlider.addEventListener('input', function(e) {
            updateBudgetSimulator(e.target.value);
        });

        // Initialize Simulator
        updateBudgetSimulator(5000);

        // Transaction Ledger Sandbox Logic
        let sandboxBalance = 1450.00;
        let sandboxInflow = 1800.00;
        let sandboxOutflow = 350.00;
        
        const initialSandboxItems = [
            { desc: '💼 Monthly Salary', amount: 1800.00, type: 'inflow', cat: 'briefcase', date: 'Just now' },
            { desc: '🏠 Rent Payment', amount: -300.00, type: 'outflow', cat: 'home', date: '5 mins ago' },
            { desc: '🍕 Dinner Outing', amount: -50.00, type: 'outflow', cat: 'coffee', date: '10 mins ago' }
        ];

        const ledgerBalance = document.getElementById('ledgBalance');
        const ledgerInflow = document.getElementById('ledgInflow');
        const ledgerOutflow = document.getElementById('ledgOutflow');
        const ledgerList = document.getElementById('sandboxLedgerList');

        function formatCurrency(val) {
            return (val < 0 ? '-' : '') + '$' + Math.abs(val).toFixed(2);
        }

        function updateLedgerDisplays() {
            ledgerBalance.textContent = formatCurrency(sandboxBalance);
            ledgerInflow.textContent = formatCurrency(sandboxInflow);
            ledgerOutflow.textContent = formatCurrency(sandboxOutflow);

            if (sandboxBalance < 0) {
                ledgerBalance.style.color = 'var(--danger)';
            } else {
                ledgerBalance.style.color = 'var(--brand-a)';
            }
        }

        function createLedgerItemDOM(item) {
            const div = document.createElement('div');
            div.className = 'ledger-item';
            
            const isOut = item.type === 'outflow';
            const sign = isOut ? '-' : '+';
            const amtClass = isOut ? 'outflow' : 'inflow';
            const iconClass = isOut ? 'outflow' : 'inflow';
            const absAmt = Math.abs(item.amount);

            div.innerHTML = `
                <div class="li-desc">
                    <div class="li-icon ${iconClass}">
                        <i data-lucide="${item.cat}" style="width: 14px; height: 14px;"></i>
                    </div>
                    <div class="li-text">
                        <h6>${item.desc}</h6>
                        <p>${item.date}</p>
                    </div>
                </div>
                <div class="li-amt ${amtClass}">
                    ${sign}$${absAmt.toFixed(2)}
                </div>
            `;
            return div;
        }

        function renderSandboxList() {
            ledgerList.innerHTML = '';
            initialSandboxItems.forEach(item => {
                const dom = createLedgerItemDOM(item);
                ledgerList.appendChild(dom);
            });
            lucide.createIcons();
        }

        function addQuickPreset(name, amount, type) {
            addSandboxTransaction(name, amount, type);
        }

        function addCustomSandboxItem() {
            const descInput = document.getElementById('sbDesc');
            const amtInput = document.getElementById('sbAmt');
            const typeInput = document.getElementById('sbType');

            const desc = descInput.value.trim() || 'Custom Activity';
            const rawAmt = parseFloat(amtInput.value);
            const type = typeInput.value;

            if (isNaN(rawAmt) || rawAmt <= 0) {
                alert('Please enter a valid amount greater than zero.');
                return;
            }

            const amount = type === 'outflow' ? -rawAmt : rawAmt;
            addSandboxTransaction(desc, amount, type);

            // Clean inputs
            descInput.value = '';
            amtInput.value = '';
        }

        function addSandboxTransaction(desc, amount, type) {
            const cat = type === 'inflow' ? 'arrow-up-right' : 'arrow-down-left';
            const item = { desc, amount, type, cat, date: 'Just now' };

            // Update local totals
            if (type === 'inflow') {
                sandboxInflow += Math.abs(amount);
                sandboxBalance += Math.abs(amount);
            } else {
                sandboxOutflow += Math.abs(amount);
                sandboxBalance -= Math.abs(amount);
            }

            updateLedgerDisplays();

            // Prepend DOM
            const dom = createLedgerItemDOM(item);
            if (ledgerList.firstChild) {
                ledgerList.insertBefore(dom, ledgerList.firstChild);
            } else {
                ledgerList.appendChild(dom);
            }
            lucide.createIcons();
        }

        function resetSandbox(e) {
            if (e) e.preventDefault();
            sandboxBalance = 1450.00;
            sandboxInflow = 1800.00;
            sandboxOutflow = 350.00;
            updateLedgerDisplays();
            renderSandboxList();
        }

        // Initialize Ledger Sandbox
        updateLedgerDisplays();
        renderSandboxList();
    </script>
</body>
