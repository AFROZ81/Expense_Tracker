@{
    Layout = null;
    ViewData["Title"] = "ExpenseTracker";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script>
        (function () {
            var savedTheme = localStorage.getItem('theme') || 'light';
            if (savedTheme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
                document.documentElement.setAttribute('data-bs-theme', 'dark');
            } else {
                document.documentElement.removeAttribute('data-theme');
                document.documentElement.setAttribute('data-bs-theme', 'light');
            }
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700;800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-main: #f2f7f9;
            --bg-soft: #e7f0f4;
            --text-primary: #0f172a;
            --text-muted: #475569;
            --line: rgba(71, 85, 105, 0.24);
            --card-bg: rgba(255, 255, 255, 0.82);
            --brand-a: #0ea5e9;
            --brand-b: #10b981;
            --brand-c: #22d3ee;
            --money-grid: rgba(15, 23, 42, 0.07);
            --money-wave: rgba(14, 165, 233, 0.12);
            --money-wave-2: rgba(16, 185, 129, 0.1);
            --glow-a: rgba(14, 165, 233, 0.2);
            --glow-b: rgba(16, 185, 129, 0.18);
            --glow-c: rgba(34, 211, 238, 0.12);
            --topbar-bg: rgba(255, 255, 255, 0.62);
        }

        [data-theme="dark"] {
            --bg-main: #07101f;
            --bg-soft: #101d33;
            --text-primary: #e6edf8;
            --text-muted: #9fb2cf;
            --line: rgba(148, 163, 184, 0.2);
            --card-bg: rgba(12, 21, 40, 0.62);
            --money-grid: rgba(148, 163, 184, 0.1);
            --money-wave: rgba(14, 165, 233, 0.16);
            --money-wave-2: rgba(16, 185, 129, 0.14);
            --glow-a: rgba(14, 165, 233, 0.24);
            --glow-b: rgba(16, 185, 129, 0.22);
            --glow-c: rgba(34, 211, 238, 0.16);
            --topbar-bg: rgba(6, 11, 22, 0.42);
        }

        * { box-sizing: border-box; }

        html, body {
            width: 100%;
            height: 100%;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Manrope', sans-serif;
            color: var(--text-primary);
            background: var(--bg-main);
            overflow: hidden;
            position: relative;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .hero-page {
            width: 100vw;
            height: 100vh;
            position: relative;
            isolation: isolate;
            display: flex;
            flex-direction: column;
        }

        .bg-noise {
            position: absolute;
            inset: 0;
            background-image:
                radial-gradient(circle at 15% 20%, var(--money-wave), transparent 34%),
                radial-gradient(circle at 85% 75%, var(--money-wave-2), transparent 36%);
            pointer-events: none;
        }

        .bg-grid {
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(to right, var(--money-grid) 1px, transparent 1px),
                linear-gradient(to bottom, var(--money-grid) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }

        .bg-glow-a,
        .bg-glow-b,
        .bg-glow-c {
            position: absolute;
            border-radius: 999px;
            filter: blur(120px);
            pointer-events: none;
        }

        .bg-glow-a {
            width: 460px;
            height: 460px;
            top: -120px;
            left: -120px;
            background: var(--glow-a);
        }

        .bg-glow-b {
            width: 420px;
            height: 420px;
            right: -130px;
            bottom: -140px;
            background: var(--glow-b);
        }

        .bg-glow-c {
            width: 360px;
            height: 360px;
            top: 40%;
            left: 52%;
            transform: translate(-50%, -50%);
            background: var(--glow-c);
        }

        .topbar {
            position: relative;
            z-index: 3;
            height: 82px;
            border-bottom: 1px solid var(--line);
            background: var(--topbar-bg);
            backdrop-filter: blur(12px);
            display: flex;
            align-items: center;
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }

        .wrap {
            width: min(1360px, 96vw);
            margin: 0 auto;
        }

        .topbar-inner {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .brand {
            text-decoration: none;
            color: var(--text-primary);
            display: inline-flex;
            align-items: center;
            gap: 12px;
            font-family: 'Outfit', sans-serif;
            font-size: 1.2rem;
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        .brand-mark {
            width: 36px;
            height: 36px;
            border-radius: 11px;
            background: linear-gradient(145deg, var(--brand-a), var(--brand-b));
            box-shadow: 0 14px 28px rgba(14, 165, 233, 0.35);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .brand-mark svg {
            width: 20px;
            height: 20px;
            color: #f8fafc;
            position: relative;
            z-index: 1;
        }

        .brand-mark::after {
            content: '';
            position: absolute;
            width: 150%;
            height: 150%;
            top: -50%;
            left: 20%;
            background: rgba(255,255,255,0.2);
            transform: rotate(30deg);
        }

        .top-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .theme-btn {
            width: 42px;
            height: 42px;
            border-radius: 999px;
            border: 1px solid var(--line);
            background: var(--card-bg);
            color: var(--text-primary);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.04rem;
            cursor: pointer;
        }

        .btn-auth {
            text-decoration: none;
            border-radius: 12px;
            padding: 10px 16px;
            font-weight: 800;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-signin {
            color: var(--text-primary);
            border: 1px solid var(--line);
            background: var(--card-bg);
        }

        .btn-signup {
            color: #fff;
            border: none;
            background: linear-gradient(135deg, var(--brand-a), var(--brand-b));
        }

        .hero-main {
            position: relative;
            z-index: 3;
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px 0 30px;
        }

        .hero-content {
            width: min(980px, 95vw);
            text-align: center;
        }

        .logo-shell {
            width: 142px;
            height: 142px;
            margin: 0 auto 18px;
            border-radius: 999px;
            display: grid;
            place-items: center;
            background: radial-gradient(circle at 35% 30%, #22d3ee, #0ea5e9 58%, #0f766e 100%);
            box-shadow: 0 0 0 8px rgba(14,165,233,0.18), 0 22px 42px rgba(14,165,233,0.35);
            position: relative;
        }

        .logo-shell::before {
            content: '';
            position: absolute;
            inset: -14px;
            border: 1px solid rgba(148,163,184,0.26);
            border-radius: inherit;
        }

        .logo-shell svg {
            width: 72px;
            height: 72px;
            color: #f8fafc;
        }

        .hero-title {
            margin: 0;
            font-family: 'Outfit', sans-serif;
            font-size: clamp(2.25rem, 4.2vw, 3.9rem);
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1.06;
        }

        .hero-line {
            width: 220px;
            height: 4px;
            margin: 14px auto 16px;
            border-radius: 999px;
            background: linear-gradient(90deg, var(--brand-a), var(--brand-c), var(--brand-b));
            box-shadow: 0 0 20px rgba(34, 211, 238, 0.4);
        }

        .hero-sub {
            margin: 0 auto;
            max-width: 66ch;
            color: var(--text-muted);
            font-size: 1.03rem;
            line-height: 1.58;
        }

        .feature-grid {
            margin-top: 28px;
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 12px;
            text-align: left;
        }

        .feature-card {
            background: var(--card-bg);
            border: 1px solid var(--line);
            border-radius: 18px;
            padding: 16px;
            backdrop-filter: blur(10px);
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }

        .icon-box {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 11px;
        }

        .icon-box svg {
            width: 20px;
            height: 20px;
        }

        .icon-security { background: rgba(14,165,233,0.18); color: #38bdf8; }
        .icon-planning { background: rgba(16,185,129,0.18); color: #34d399; }
        .icon-export { background: rgba(13,148,136,0.2); color: #2dd4bf; }

        .feature-card h3 {
            margin: 0;
            font-size: 1.01rem;
            font-weight: 800;
            font-family: 'Outfit', sans-serif;
        }

        .feature-card p {
            margin: 8px 0 0;
            color: var(--text-muted);
            font-size: 0.9rem;
            line-height: 1.5;
        }
    </style>
</head>
<body>
    <div class="hero-page">
        <div class="bg-noise"></div>
        <div class="bg-grid"></div>
        <div class="bg-glow-a"></div>
        <div class="bg-glow-b"></div>
        <div class="bg-glow-c"></div>

        <header class="topbar">
            <div class="wrap topbar-inner">
                <a class="brand" href="@Url.Action("Index", "Home")">
                    <span class="brand-mark" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M4 7.5C4 6.12 5.12 5 6.5 5H17.5C18.88 5 20 6.12 20 7.5V16.5C20 17.88 18.88 19 17.5 19H6.5C5.12 19 4 17.88 4 16.5V7.5Z" stroke="currentColor" stroke-width="1.8"/>
                            <path d="M15.5 12H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            <circle cx="15.2" cy="12" r="1.2" fill="currentColor"/>
                        </svg>
                    </span>
                    ExpenseTracker
                </a>

                <div class="top-actions">
                    <button id="themeToggle" class="theme-btn" type="button" aria-label="Toggle theme">
                        <span id="themeGlyph">🌙</span>
                    </button>
                    <a href="@Url.Action("Login", "Account")" class="btn-auth btn-signin">Sign In</a>
                    <a href="@Url.Action("Register", "Account")" class="btn-auth btn-signup">Sign Up</a>
                </div>
            </div>
        </header>

        <main class="hero-main">
            <section class="hero-content">
                <div class="logo-shell" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 3.5L18.5 7V12.5C18.5 16.22 15.82 19.68 12 20.5C8.18 19.68 5.5 16.22 5.5 12.5V7L12 3.5Z" stroke="currentColor" stroke-width="1.6"/>
                        <path d="M9.5 12L11.2 13.7L14.8 10.1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>

                <h1 class="hero-title">A smarter way to manage personal finance.</h1>
                <div class="hero-line"></div>
                <p class="hero-sub">
                    Track expenses and income, keep account balances accurate, plan budgets, automate recurring entries, and export clean reports from one secure dashboard.
                </p>

                <div class="feature-grid">
                    <article class="feature-card">
                        <div class="icon-box icon-security">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 3L19 7V12C19 16.2 16.1 19.9 12 21C7.9 19.9 5 16.2 5 12V7L12 3Z" stroke="currentColor" stroke-width="1.7"/>
                            </svg>
                        </div>
                        <h3>Secure by Design</h3>
                        <p>User-scoped data and authenticated flows keep each financial workspace private and protected.</p>
                    </article>

                    <article class="feature-card">
                        <div class="icon-box icon-planning">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M4 19H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                <path d="M7 16V10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                <path d="M12 16V7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                <path d="M17 16V12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <h3>Clarity and Planning</h3>
                        <p>Use budgets, monthly insights, charts, and recurring rules to stay in control of daily money decisions.</p>
                    </article>

                    <article class="feature-card">
                        <div class="icon-box icon-export">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 14V4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                <path d="M8.5 7.5L12 4L15.5 7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M5 14.5V17.5C5 18.6 5.9 19.5 7 19.5H17C18.1 19.5 19 18.6 19 17.5V14.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <h3>Export Ready</h3>
                        <p>Create professional PDF and Excel outputs for statements, summaries, and record keeping.</p>
                    </article>
                </div>
            </section>
        </main>
    </div>

    <script>
        (function () {
            const html = document.documentElement;
            const toggle = document.getElementById('themeToggle');
            const glyph = document.getElementById('themeGlyph');

            const setTheme = (theme) => {
                if (theme === 'dark') {
                    html.setAttribute('data-theme', 'dark');
                    html.setAttribute('data-bs-theme', 'dark');
                    glyph.textContent = '☀️';
                } else {
                    html.removeAttribute('data-theme');
                    html.setAttribute('data-bs-theme', 'light');
                    glyph.textContent = '🌙';
                }
                localStorage.setItem('theme', theme);
            };

            const saved = localStorage.getItem('theme');
            setTheme(saved === 'dark' ? 'dark' : 'light');

            toggle.addEventListener('click', function () {
                const isDark = html.getAttribute('data-theme') === 'dark';
                setTheme(isDark ? 'light' : 'dark');
            });
        })();
    </script>
</body>
</html>
