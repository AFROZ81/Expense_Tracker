@model IEnumerable<ExpenseTracker.Models.Entities.RecurringTransaction>

@{
    ViewData["Title"] = "Recurring Transactions";
}

<style>
    :root {
        --rule-accent: #4f46e5;
        --rule-expense: #ef4444;
        --rule-income: #10b981;
    }

    .rules-page-wrapper {
        animation: fadeInRules 0.5s ease-out;
    }

    @@keyframes fadeInRules {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .rules-hero-card {
        background: linear-gradient(120deg, #1e293b 0%, #0f172a 100%);
        border-radius: 30px;
        padding: 32px;
        color: #f8fafc;
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 22px 50px rgba(15, 23, 42, 0.28);
    }

    .rules-hero-card::after {
        content: '';
        position: absolute;
        width: 280px;
        height: 280px;
        right: -120px;
        top: -130px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(129, 140, 248, 0.35), transparent 65%);
        pointer-events: none;
    }

    .rules-title {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 8px;
        letter-spacing: -0.02em;
        color: #f8fafc;
        text-shadow: 0 2px 10px rgba(2, 6, 23, 0.35);
    }

    .rules-subtitle {
        margin-bottom: 0;
        color: rgba(226, 232, 240, 0.92);
        max-width: 520px;
    }

    .rules-add-btn {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        border: none;
        color: #fff;
        border-radius: 14px;
        padding: 12px 22px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.25s ease;
        box-shadow: 0 10px 24px rgba(79, 70, 229, 0.32);
        text-decoration: none;
        position: relative;
        z-index: 3;
    }

    .rules-add-btn:hover {
        transform: translateY(-2px);
        color: #fff;
        box-shadow: 0 16px 30px rgba(79, 70, 229, 0.45);
    }

    .rule-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(330px, 1fr));
        gap: 22px;
    }

    .rule-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
        transition: all 0.25s ease;
    }

    .rule-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 18px 30px rgba(15, 23, 42, 0.1);
    }

    .rule-meta {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 18px;
    }

    .rule-icon {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .rule-icon.expense {
        color: var(--rule-expense);
        background: rgba(239, 68, 68, 0.12);
    }

    .rule-icon.income {
        color: var(--rule-income);
        background: rgba(16, 185, 129, 0.14);
    }

    .rule-state {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 4px 12px;
        border-radius: 999px;
    }

    .rule-state.active {
        background: rgba(16, 185, 129, 0.14);
        color: #047857;
    }

    .rule-state.paused {
        background: rgba(100, 116, 139, 0.16);
        color: #334155;
    }

    [data-theme="dark"] .rule-state.active {
        color: #6ee7b7;
    }

    [data-theme="dark"] .rule-state.paused {
        color: #cbd5e1;
    }

    .rule-desc {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--text-main);
        margin-bottom: 4px;
    }

    .rule-amount {
        font-size: 1.55rem;
        font-weight: 800;
        letter-spacing: -0.01em;
        margin-bottom: 0;
    }

    .rule-amount.expense {
        color: var(--rule-expense);
    }

    .rule-amount.income {
        color: var(--rule-income);
    }

    .rule-frequency {
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 700;
    }

    .rule-info-box {
        margin-top: 16px;
        padding: 14px;
        border-radius: 14px;
        background: var(--bg);
        border: 1px solid var(--border);
    }

    .rule-info-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        font-size: 0.86rem;
    }

    .rule-info-row + .rule-info-row {
        margin-top: 8px;
    }

    .rule-info-row span:first-child {
        color: var(--muted);
        font-weight: 600;
    }

    .rule-info-row span:last-child {
        color: var(--text-main);
        font-weight: 700;
        text-align: right;
    }

    .rule-delete-btn {
        border: none;
        background: rgba(239, 68, 68, 0.12);
        color: #dc2626;
        width: 42px;
        height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        transition: all 0.2s ease;
        box-shadow: inset 0 0 0 1px rgba(239, 68, 68, 0.2);
    }

    .rule-delete-btn:hover {
        background: rgba(239, 68, 68, 0.2);
        color: #b91c1c;
        transform: translateY(-1px);
    }

    [data-theme="dark"] .rule-delete-btn {
        background: rgba(248, 113, 113, 0.16);
        color: #fda4af;
        box-shadow: inset 0 0 0 1px rgba(248, 113, 113, 0.28);
    }

    [data-theme="dark"] .rule-delete-btn:hover {
        background: rgba(248, 113, 113, 0.24);
        color: #fecaca;
    }

    .empty-rules-state {
        background: var(--card);
        border: 1px dashed var(--border);
        border-radius: 24px;
        padding: 56px 26px;
        text-align: center;
    }

    .empty-rules-state .empty-icon {
        width: 68px;
        height: 68px;
        border-radius: 20px;
        margin: 0 auto 16px;
        background: rgba(99, 102, 241, 0.12);
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    @@media (max-width: 767.98px) {
        .rules-hero-card {
            padding: 24px;
        }

        .rules-title {
            font-size: 1.55rem;
        }
    }
</style>

<div class="rules-page-wrapper">
    <div class="rules-hero-card d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-4">
        <div style="position:relative;z-index:2;">
            <h2 class="rules-title">Recurring Rules</h2>
            <p class="rules-subtitle">Set up daily, weekly, or monthly automations for incomes and expenses so your tracking stays current without manual entry.</p>
        </div>
        <a asp-action="Create" class="rules-add-btn">
            <i data-lucide="plus" style="width:18px;height:18px;"></i>
            New Rule
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-rules-state">
            <div class="empty-icon">
                <i data-lucide="refresh-cw" style="width: 30px; height: 30px;"></i>
            </div>
            <h4 class="fw-800 text-main-adaptive mb-2">No Automations Yet</h4>
            <p class="text-muted mb-4">Create your first recurring rule to automate scheduled income or expense entries.</p>
            <a asp-action="Create" class="rules-add-btn">
                <i data-lucide="plus" style="width:18px;height:18px;"></i>
                Create First Rule
            </a>
        </div>
    }
    else
    {
        <div class="rule-grid">
            @foreach (var item in Model)
            {
                var isExpense = item.Type == ExpenseTracker.Models.Entities.TransactionType.Expense;
                var iconClass = isExpense ? "expense" : "income";
                var iconName = isExpense ? "arrow-down-right" : "arrow-up-right";
                var amountClass = isExpense ? "expense" : "income";
                var stateClass = item.IsActive ? "active" : "paused";
                var stateText = item.IsActive ? "Active" : "Paused";

                <div class="rule-card">
                    <div class="rule-meta">
                        <div class="rule-icon @iconClass">
                            <i data-lucide="@iconName"></i>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="rule-state @stateClass">@stateText</span>
                            <button type="button" class="rule-delete-btn btn-delete-rule-trigger" data-id="@item.Id" title="Delete Rule" aria-label="Delete Rule">
                                <i data-lucide="trash-2" style="width:20px;height:20px;"></i>
                            </button>
                        </div>
                    </div>

                    <h3 class="rule-desc">@item.Description</h3>
                    <div class="d-flex align-items-baseline gap-2">
                        <p class="rule-amount @amountClass mb-0">@item.Amount.ToString("C")</p>
                        <span class="rule-frequency">/ @item.Frequency</span>
                    </div>

                    <div class="rule-info-box">
                        <div class="rule-info-row">
                            <span>Account</span>
                            <span>@item.Account?.Name</span>
                        </div>
                        <div class="rule-info-row">
                            <span>Last Processed</span>
                            <span>@(item.LastProcessedDate?.ToString("dd MMM yyyy") ?? "Never")</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteRuleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-custom-content">
            <div class="modal-header modal-custom-header">
                <div class="mb-3">
                    <div class="icon-box bg-danger-subtle text-danger p-3 rounded-circle d-inline-flex">
                        <i data-lucide="trash-2" size="32"></i>
                    </div>
                </div>
                <h4 class="fw-800 text-main-adaptive mb-0">Delete Rule</h4>
            </div>
            <div class="modal-body modal-custom-body">
                Are you sure you want to delete this recurring rule? This action cannot be undone.
            </div>
            <div class="modal-footer modal-custom-footer">
                <button type="button" class="btn-modal-cancel flex-grow-1" data-bs-dismiss="modal">Cancel</button>
                <a id="confirmDeleteRuleBtn" href="#" class="btn-modal-confirm flex-grow-1 text-decoration-none text-center">Delete</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            lucide.createIcons();

            $('.btn-delete-rule-trigger').on('click', function (e) {
                e.preventDefault();
                const ruleId = $(this).data('id');
                const deleteUrl = `/RecurringTransaction/Delete/${ruleId}`;
                $('#confirmDeleteRuleBtn').attr('href', deleteUrl);
                const modal = new bootstrap.Modal(document.getElementById('deleteRuleModal'));
                modal.show();
            });
        });
    </script>
}

