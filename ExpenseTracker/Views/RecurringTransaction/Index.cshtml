@model IEnumerable<ExpenseTracker.Models.Entities.RecurringTransaction>

@{
    ViewData["Title"] = "Recurring Transactions";
}

<style>
    :root { --accent:#0ea5e9; --accent-hover:#0284c7; --accent-soft:rgba(14,165,233,0.08); --success:#10b981; --success-soft:rgba(16,185,129,0.08); --danger:#ef4444; --danger-soft:rgba(239,68,68,0.08); }
    .rec-page { animation:pageIn 0.45s ease-out; }
    @@keyframes pageIn { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
    @@keyframes cardIn { from{opacity:0;transform:translateY(10px) scale(0.98)} to{opacity:1;transform:translateY(0) scale(1)} }

    /* Hero */
    .rec-hero { background:linear-gradient(135deg,#1e293b 0%,#0f172a 100%); border-radius:22px; padding:30px 34px; color:#f8fafc; margin-bottom:28px; display:flex; justify-content:space-between; align-items:center; position:relative; overflow:hidden; box-shadow:0 16px 40px rgba(0,0,0,0.2); gap:20px; flex-wrap:wrap; }
    .rec-hero::after { content:''; position:absolute; width:220px; height:220px; right:-80px; top:-100px; border-radius:50%; background:radial-gradient(circle,rgba(14,165,233,0.3),transparent 70%); pointer-events:none; }
    .rec-hero h1 { font-size:1.5rem; font-weight:800; margin:0 0 6px; letter-spacing:-0.02em; color:#f8fafc; position:relative; z-index:2; }
    .rec-hero p { font-size:0.84rem; color:rgba(226,232,240,0.85); margin:0; max-width:500px; position:relative; z-index:2; }
    .btn-add { display:inline-flex; align-items:center; gap:8px; background:linear-gradient(135deg,#0ea5e9,#10b981); color:white; border:none; padding:12px 24px; border-radius:12px; font-weight:700; font-size:0.88rem; text-decoration:none; transition:all 0.22s; box-shadow:0 8px 20px rgba(14,165,233,0.3); position:relative; z-index:2; }
    .btn-add:hover { transform:translateY(-2px); box-shadow:0 12px 28px rgba(14,165,233,0.4); color:white; }

    .rec-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(320px,1fr)); gap:16px; }

    /* Rule Card */
    .rec-card { background:var(--card); border:1px solid var(--border); border-radius:18px; padding:22px 24px; transition:all 0.25s; animation:cardIn 0.35s ease-out both; }
    .rec-card:hover { transform:translateY(-3px); box-shadow:0 10px 28px rgba(0,0,0,0.07); }
    .rec-card:nth-child(1){animation-delay:.03s} .rec-card:nth-child(2){animation-delay:.06s} .rec-card:nth-child(3){animation-delay:.09s}
    .rec-card:nth-child(4){animation-delay:.12s} .rec-card:nth-child(5){animation-delay:.15s} .rec-card:nth-child(6){animation-delay:.18s}

    .rec-card-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:16px; }
    .rec-type-icon { width:48px; height:48px; border-radius:14px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .rec-type-icon.expense { background:var(--danger-soft); color:var(--danger); }
    .rec-type-icon.income { background:var(--success-soft); color:var(--success); }
    [data-theme="dark"] .rec-type-icon.expense { background:rgba(239,68,68,0.15); color:#f87171; }
    [data-theme="dark"] .rec-type-icon.income { background:rgba(16,185,129,0.15); color:#4ade80; }

    .rec-card-actions { display:flex; align-items:center; gap:8px; }
    .rec-status { font-size:0.68rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; padding:4px 12px; border-radius:20px; }
    .rec-status.active { background:var(--success-soft); color:var(--success); }
    .rec-status.paused { background:rgba(100,116,139,0.1); color:var(--muted); }
    [data-theme="dark"] .rec-status.active { background:rgba(34,197,94,0.15); color:#4ade80; }
    [data-theme="dark"] .rec-status.paused { background:rgba(148,163,184,0.12); color:#94a3b8; }

    .rec-del-btn { width:36px; height:36px; border-radius:10px; border:1px solid transparent; background:var(--danger-soft); color:var(--danger); display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all 0.2s; }
    .rec-del-btn:hover { background:var(--danger); color:white; transform:translateY(-1px); }
    [data-theme="dark"] .rec-del-btn { background:rgba(248,113,113,0.15); color:#f87171; }
    [data-theme="dark"] .rec-del-btn:hover { background:var(--danger); color:white; }

    .rec-desc { font-size:1.1rem; font-weight:800; color:var(--text-main); margin:0 0 6px; }
    .rec-amount-row { display:flex; align-items:baseline; gap:8px; margin-bottom:16px; }
    .rec-amount { font-size:1.4rem; font-weight:800; letter-spacing:-0.01em; }
    .rec-amount.expense { color:var(--danger); }
    .rec-amount.income { color:var(--success); }
    [data-theme="dark"] .rec-amount.expense { color:#f87171; }
    [data-theme="dark"] .rec-amount.income { color:#4ade80; }
    .rec-freq { font-size:0.82rem; font-weight:700; color:var(--muted); }

    .rec-info { background:var(--bg); border:1px solid var(--border); border-radius:12px; padding:14px 16px; }
    .rec-info-row { display:flex; justify-content:space-between; font-size:0.82rem; }
    .rec-info-row + .rec-info-row { margin-top:8px; }
    .rec-info-row span:first-child { color:var(--muted); font-weight:600; }
    .rec-info-row span:last-child { color:var(--text-main); font-weight:700; text-align:right; }

    /* Empty */
    .empty-card { grid-column:1/-1; text-align:center; padding:56px 24px; background:var(--card); border:1px dashed var(--border); border-radius:20px; }
    .empty-icon { width:72px; height:72px; border-radius:20px; background:var(--accent-soft); color:var(--accent); display:flex; align-items:center; justify-content:center; margin:0 auto 18px; }
    .empty-card h5 { font-size:1.05rem; font-weight:800; color:var(--text-main); margin:0 0 6px; }
    .empty-card p { font-size:0.84rem; color:var(--muted); margin:0 0 20px; }

    /* Modal */
    .del-modal .modal-content { border-radius:24px; border:none; box-shadow:0 30px 80px rgba(0,0,0,0.18); background:var(--card); }
    .del-modal-icon { width:68px; height:68px; border-radius:50%; background:var(--danger-soft); color:var(--danger); display:flex; align-items:center; justify-content:center; margin:0 auto 18px; }
    .modal-btn-del { background:var(--danger); color:white; border:none; padding:12px 28px; border-radius:12px; font-weight:700; transition:all 0.2s; text-decoration:none; }
    .modal-btn-del:hover { background:#dc2626; transform:translateY(-1px); box-shadow:0 8px 20px rgba(239,68,68,0.25); color:white; }
    .modal-btn-cancel { background:var(--bg); color:var(--muted); border:1px solid var(--border); padding:12px 28px; border-radius:12px; font-weight:700; transition:all 0.2s; }
    .modal-btn-cancel:hover { background:var(--border); color:var(--text-main); }

    @@media (max-width:767.98px) {
        .rec-hero { padding:22px 20px; border-radius:18px; flex-direction:column; align-items:stretch; }
        .rec-hero h1 { font-size:1.25rem; }
        .btn-add { justify-content:center; }
        .rec-grid { grid-template-columns:1fr; gap:12px; }
        .rec-card { padding:18px 16px; border-radius:16px; }
        .rec-desc { font-size:1rem; }
        .rec-amount { font-size:1.2rem; }
        .empty-card { padding:40px 16px; }
    }
</style>

<div class="rec-page">
    <div class="rec-hero">
        <div>
            <h1>Recurring Rules</h1>
            <p>Automate daily, weekly, or monthly incomes and expenses so your tracking stays current without manual entry.</p>
        </div>
        <a asp-action="Create" class="btn-add"><i data-lucide="plus" style="width:18px;height:18px"></i> New Rule</a>
    </div>

    <div class="rec-grid">
        @if (!Model.Any())
        {
            <div class="empty-card">
                <div class="empty-icon"><i data-lucide="refresh-cw" style="width:28px;height:28px"></i></div>
                <h5>No Automations Yet</h5>
                <p>Create your first recurring rule to automate scheduled entries.</p>
                <a asp-action="Create" class="btn-add"><i data-lucide="plus" style="width:18px;height:18px"></i> Create First Rule</a>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                var isExpense = item.Type == ExpenseTracker.Models.Entities.TransactionType.Expense;
                var iconClass = isExpense ? "expense" : "income";
                var iconName = isExpense ? "arrow-down-right" : "arrow-up-right";
                var stateClass = item.IsActive ? "active" : "paused";
                var stateText = item.IsActive ? "Active" : "Paused";

                <div class="rec-card">
                    <div class="rec-card-top">
                        <div class="rec-type-icon @iconClass">
                            <i data-lucide="@iconName" style="width:22px;height:22px"></i>
                        </div>
                        <div class="rec-card-actions">
                            <span class="rec-status @stateClass">@stateText</span>
                            <button type="button" class="rec-del-btn btn-delete-rule-trigger" data-id="@item.Id" title="Delete Rule">
                                <i data-lucide="trash-2" style="width:16px;height:16px"></i>
                            </button>
                        </div>
                    </div>

                    <h3 class="rec-desc">@item.Description</h3>
                    <div class="rec-amount-row">
                        <span class="rec-amount @iconClass">₹@item.Amount.ToString("N2")</span>
                        <span class="rec-freq">/ @item.Frequency</span>
                    </div>

                    <div class="rec-info">
                        <div class="rec-info-row">
                            <span>Account</span>
                            <span>@item.Account?.Name</span>
                        </div>
                        <div class="rec-info-row">
                            <span>Last Processed</span>
                            <span>@(item.LastProcessedDate?.ToString("dd MMM yyyy") ?? "Never")</span>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<div class="modal fade del-modal" id="deleteRuleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px">
        <div class="modal-content">
            <div class="modal-body p-5 text-center">
                <div class="del-modal-icon"><i data-lucide="trash-2" style="width:28px;height:28px"></i></div>
                <h4 class="fw-800 text-main-adaptive mb-2" style="font-size:1.15rem">Delete Rule?</h4>
                <p class="text-muted mb-4" style="font-size:0.88rem">This action cannot be undone.</p>
                <div class="d-flex gap-3 justify-content-center">
                    <button type="button" class="modal-btn-cancel flex-grow-1" data-bs-dismiss="modal">Cancel</button>
                    <a id="confirmDeleteRuleBtn" href="#" class="modal-btn-del flex-grow-1 text-decoration-none text-center">Delete</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            lucide.createIcons();
            $('.btn-delete-rule-trigger').on('click', function(e) {
                e.preventDefault();
                $('#confirmDeleteRuleBtn').attr('href', `/RecurringTransaction/Delete/${$(this).data('id')}`);
                new bootstrap.Modal(document.getElementById('deleteRuleModal')).show();
            });
        });
    </script>
}
