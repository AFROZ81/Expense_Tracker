@model IEnumerable<ExpenseTracker.Models.Entities.RecurringTransaction>

@{
    ViewData["Title"] = "Recurring Transactions";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-800 text-main-adaptive mb-1">Recurring Rules</h2>
            <p class="text-muted">Automate your regular income and expenses.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-3 px-4 shadow-sm">
            <i data-lucide="plus" class="me-2"></i> New Rule
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="glass-card p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box @(item.Type == ExpenseTracker.Models.Entities.TransactionType.Expense ? "bg-danger-subtle text-danger" : "bg-success-subtle text-success") p-3 rounded-4">
                            <i data-lucide="@(item.Type == ExpenseTracker.Models.Entities.TransactionType.Expense ? "arrow-down-right" : "arrow-up-right")"></i>
                        </div>
                        <div class="text-end">
                            <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary") rounded-pill mb-1">@(item.IsActive ? "Active" : "Paused")</span>
                            <div class="dropdown">
                                <button class="btn btn-link text-muted p-0" data-bs-toggle="dropdown">
                                    <i data-lucide="more-vertical" size="18"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-3">
                                    <li><a class="dropdown-item text-danger fw-600" asp-action="Delete" asp-route-id="@item.Id" onclick="return confirm('Delete this rule?')">Delete Rule</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <h5 class="fw-700 mb-1">@item.Description</h5>
                    <div class="d-flex align-items-baseline gap-2 mb-3">
                        <h4 class="fw-800 mb-0 @(item.Type == ExpenseTracker.Models.Entities.TransactionType.Expense ? "text-danger" : "text-success")">
                            @item.Amount.ToString("C")
                        </h4>
                        <span class="text-muted small fw-600">/ @item.Frequency</span>
                    </div>

                    <div class="bg-light rounded-3 p-3 small">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Account:</span>
                            <span class="fw-600">@item.Account?.Name</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Last Processed:</span>
                            <span class="fw-600">@(item.LastProcessedDate?.ToShortDateString() ?? "Never")</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

