@model ExpenseTracker.Models.Entities.RecurringTransaction

@{
    ViewData["Title"] = "New Recurring Rule";
}

<style>
    :root { --accent:#0ea5e9; --accent-hover:#0284c7; --accent-soft:rgba(14,165,233,0.08); --success:#10b981; --success-soft:rgba(16,185,129,0.08); --danger:#ef4444; --danger-soft:rgba(239,68,68,0.08); }
    .form-page { animation:slideIn 0.45s ease-out; }
    @@keyframes slideIn { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }

    /* Hero */
    .rec-hero { background:linear-gradient(135deg,#1e293b 0%,#0f172a 100%); border-radius:20px; padding:26px 30px; margin-bottom:24px; color:#f8fafc; position:relative; overflow:hidden; box-shadow:0 14px 36px rgba(0,0,0,0.2); }
    .rec-hero::after { content:''; position:absolute; width:200px; height:200px; right:-70px; top:-90px; border-radius:50%; background:radial-gradient(circle,rgba(14,165,233,0.3),transparent 70%); pointer-events:none; }
    .rec-hero h2 { font-size:1.2rem; font-weight:800; margin:0 0 6px; color:#f8fafc; position:relative; z-index:2; }
    .rec-hero p { font-size:0.82rem; color:rgba(226,232,240,0.85); margin:0; max-width:580px; position:relative; z-index:2; }

    .form-card { background:var(--card); border:1px solid var(--border); border-radius:20px; padding:28px 32px 32px; box-shadow:0 8px 30px rgba(0,0,0,0.06); }

    /* Type pills */
    .type-pills { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:24px; }
    .type-pill { height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center; gap:8px; font-weight:700; font-size:0.88rem; border:1.5px solid var(--border); background:var(--bg); color:var(--muted); cursor:pointer; transition:all 0.22s; user-select:none; }
    .type-pill:hover { border-color:rgba(14,165,233,0.3); }
    .type-pill.active.expense { border-color:rgba(239,68,68,0.35); background:var(--danger-soft); color:var(--danger); }
    .type-pill.active.income { border-color:rgba(16,185,129,0.35); background:var(--success-soft); color:var(--success); }
    [data-theme="dark"] .type-pill.active.expense { color:#f87171; }
    [data-theme="dark"] .type-pill.active.income { color:#4ade80; }

    .field-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:20px; }
    .field-group { margin-bottom:20px; }
    .field-label { font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--muted); margin-bottom:7px; display:block; }

    .input-wrap { display:flex; align-items:stretch; border:1.5px solid var(--border); border-radius:14px; background:var(--bg); transition:all 0.22s; overflow:hidden; }
    .input-wrap:focus-within { border-color:var(--accent); background:var(--card); box-shadow:0 0 0 4px rgba(14,165,233,0.1); }
    .input-wrap-icon { width:46px; min-width:46px; display:flex; align-items:center; justify-content:center; color:var(--muted); flex-shrink:0; border-right:1.5px solid var(--border); transition:all 0.22s; }
    .input-wrap:focus-within .input-wrap-icon { color:var(--accent); border-right-color:var(--accent); }
    .input-wrap input, .input-wrap select { flex:1; border:none; background:transparent; outline:none; padding:12px 14px; font-size:0.9rem; font-weight:500; color:var(--text-main); min-width:0; appearance:none; font-family:inherit; }
    .input-wrap select { cursor:pointer; }
    .input-wrap input::placeholder { color:var(--muted); opacity:0.5; }

    .amount-wrap { display:flex; align-items:stretch; border:1.5px solid var(--border); border-radius:14px; background:var(--bg); transition:all 0.22s; overflow:hidden; }
    .amount-wrap:focus-within { border-color:var(--accent); background:var(--card); box-shadow:0 0 0 4px rgba(14,165,233,0.1); }
    .currency-prefix { width:46px; min-width:46px; display:flex; align-items:center; justify-content:center; font-weight:800; color:var(--muted); font-size:1.1rem; border-right:1.5px solid var(--border); flex-shrink:0; transition:all 0.22s; }
    .amount-wrap:focus-within .currency-prefix { color:var(--accent); border-right-color:var(--accent); }
    .amount-wrap input { flex:1; border:none; background:transparent; outline:none; padding:14px 16px; font-size:1.2rem; font-weight:800; color:var(--text-main); min-width:0; font-family:inherit; }
    .amount-wrap input::placeholder { color:var(--muted); opacity:0.4; }

    .form-actions { display:flex; gap:12px; margin-top:28px; }
    .btn-cancel { flex:1; display:flex; align-items:center; justify-content:center; padding:13px 20px; border-radius:12px; font-weight:700; font-size:0.9rem; background:var(--bg); border:1px solid var(--border); color:var(--text-main); text-decoration:none; transition:all 0.2s; }
    .btn-cancel:hover { background:var(--border); color:var(--text-main); }
    .btn-submit { flex:1; display:flex; align-items:center; justify-content:center; gap:8px; background:linear-gradient(135deg,#0ea5e9,#10b981); color:white; border:none; padding:13px 20px; border-radius:12px; font-weight:700; font-size:0.9rem; transition:all 0.22s; box-shadow:0 6px 18px rgba(14,165,233,0.25); cursor:pointer; }
    .btn-submit:hover { transform:translateY(-1px); box-shadow:0 10px 26px rgba(14,165,233,0.35); color:white; }

    @@media (max-width:767.98px) {
        .rec-hero { padding:20px 18px; border-radius:16px; }
        .rec-hero h2 { font-size:1.1rem; }
        .form-card { padding:20px 18px 24px; border-radius:18px; }
        .type-pills { grid-template-columns:1fr; }
        .type-pill { height:44px; }
        .field-row { grid-template-columns:1fr; gap:0; }
        .field-group { margin-bottom:16px; }
        .field-label { font-size:0.66rem; margin-bottom:5px; }
        .input-wrap { border-radius:12px; }
        .input-wrap-icon { width:42px; min-width:42px; }
        .input-wrap-icon svg { width:16px; height:16px; }
        .input-wrap input, .input-wrap select { padding:11px 12px; font-size:0.86rem; }
        .amount-wrap { border-radius:12px; }
        .currency-prefix { width:42px; min-width:42px; font-size:1rem; }
        .amount-wrap input { padding:12px 14px; font-size:1.1rem; }
        .form-actions { flex-direction:column-reverse; }
        .btn-cancel, .btn-submit { width:100%; }
    }
</style>

<div class="form-page">
    <div class="rec-hero">
        <h2>Create Recurring Rule</h2>
        <p>Automate recurring income and expenses with schedule-aware rules that keep your balances always up to date.</p>
    </div>

    <div class="form-card">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="type-pills">
                <button type="button" id="expenseTypePill" class="type-pill expense active"><i data-lucide="arrow-down-right" style="width:14px;height:14px"></i> Expense Rule</button>
                <button type="button" id="incomeTypePill" class="type-pill income"><i data-lucide="arrow-up-right" style="width:14px;height:14px"></i> Income Rule</button>
            </div>

            <div class="field-row">
                <div>
                    <label asp-for="Type" class="field-label"></label>
                    <div class="input-wrap">
                        <div class="input-wrap-icon"><i data-lucide="layers" style="width:17px;height:17px"></i></div>
                        <select asp-for="Type" id="typeSelector" asp-items="Html.GetEnumSelectList<ExpenseTracker.Models.Entities.TransactionType>()"></select>
                    </div>
                </div>
                <div>
                    <label asp-for="Frequency" class="field-label"></label>
                    <div class="input-wrap">
                        <div class="input-wrap-icon"><i data-lucide="refresh-cw" style="width:17px;height:17px"></i></div>
                        <select asp-for="Frequency" asp-items="Html.GetEnumSelectList<ExpenseTracker.Models.Entities.Frequency>()"></select>
                    </div>
                </div>
            </div>

            <div class="field-group">
                <label asp-for="Description" class="field-label"></label>
                <div class="input-wrap">
                    <div class="input-wrap-icon"><i data-lucide="file-text" style="width:17px;height:17px"></i></div>
                    <input asp-for="Description" placeholder="e.g. Netflix subscription, Monthly salary" />
                </div>
                <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="field-group">
                <label asp-for="Amount" class="field-label"></label>
                <div class="amount-wrap">
                    <span class="currency-prefix">₹</span>
                    <input asp-for="Amount" placeholder="0.00" />
                </div>
                <span asp-validation-for="Amount" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="field-row">
                <div id="expenseCategoryGroup">
                    <label class="field-label">Expense Category</label>
                    <div class="input-wrap">
                        <div class="input-wrap-icon"><i data-lucide="tag" style="width:17px;height:17px"></i></div>
                        <select name="ExpenseCategoryId" asp-items="ViewBag.ExpenseCategoryList"></select>
                    </div>
                </div>
                <div id="incomeCategoryGroup" class="d-none">
                    <label class="field-label">Income Category</label>
                    <div class="input-wrap">
                        <div class="input-wrap-icon"><i data-lucide="briefcase" style="width:17px;height:17px"></i></div>
                        <select name="IncomeCategoryId" asp-items="ViewBag.IncomeCategoryList"></select>
                    </div>
                </div>
                <div>
                    <label asp-for="AccountId" class="field-label">Account</label>
                    <div class="input-wrap">
                        <div class="input-wrap-icon"><i data-lucide="wallet" style="width:17px;height:17px"></i></div>
                        <select asp-for="AccountId" asp-items="ViewBag.AccountList"></select>
                    </div>
                </div>
            </div>

            <div class="field-group">
                <label asp-for="StartDate" class="field-label"></label>
                <div class="input-wrap">
                    <div class="input-wrap-icon"><i data-lucide="calendar" style="width:17px;height:17px"></i></div>
                    <input asp-for="StartDate" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
            </div>

            <div class="form-actions">
                <a asp-action="Index" class="btn-cancel">Cancel</a>
                <button type="submit" class="btn-submit"><i data-lucide="check" style="width:16px;height:16px"></i> Save Rule</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function() {
            const typeSelector = document.getElementById('typeSelector');
            const expenseGroup = document.getElementById('expenseCategoryGroup');
            const incomeGroup = document.getElementById('incomeCategoryGroup');
            const expensePill = document.getElementById('expenseTypePill');
            const incomePill = document.getElementById('incomeTypePill');

            function syncTypeUI() {
                const isExpense = typeSelector.value === "0";
                expenseGroup.classList.toggle('d-none', !isExpense);
                incomeGroup.classList.toggle('d-none', isExpense);
                expensePill.classList.toggle('active', isExpense);
                incomePill.classList.toggle('active', !isExpense);
            }

            expensePill.addEventListener('click', function() { typeSelector.value = "0"; syncTypeUI(); });
            incomePill.addEventListener('click', function() { typeSelector.value = "1"; syncTypeUI(); });
            typeSelector.addEventListener('change', syncTypeUI);
            syncTypeUI();
            lucide.createIcons();
        })();
    </script>
}
