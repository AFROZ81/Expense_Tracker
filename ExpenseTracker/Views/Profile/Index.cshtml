@model ExpenseTracker.Models.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
    ViewData["HideMobileQuickAction"] = true;
    ViewData["HideSidebar"] = true;
}

<style>
    :root { --accent: #0ea5e9; --accent2: #10b981; --accent-soft: rgba(14,165,233,.10); --accent2-soft: rgba(16,185,129,.10); }
    .profile-page { animation: pageIn .42s ease-out; }
    @@keyframes pageIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .profile-shell { max-width: 900px; margin: 0 auto; }
    .profile-topbar { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 24px; }
    .back-link { display: inline-flex; align-items: center; gap: 8px; color: var(--text-main); font-weight: 700; text-decoration: none; padding: 8px 12px; border-radius: 12px; transition: all 0.2s ease; }
    .back-link:hover { color: var(--accent); transform: translateY(-1px); }
    .profile-hero { position: relative; overflow: hidden; border-radius: 28px; padding: 32px; color: #fff; background: linear-gradient(135deg, rgba(14,165,233,.95) 0%, rgba(16,185,129,.95) 100%); box-shadow: 0 20px 40px rgba(14,165,233,.18); margin-bottom: 24px; }
    .profile-hero::before { content: ''; position: absolute; top: -50%; right: -10%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(255,255,255,.15) 0%, transparent 60%); pointer-events: none; }
    .profile-hero::after { content: ''; position: absolute; bottom: -30%; left: -5%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(255,255,255,.1) 0%, transparent 60%); pointer-events: none; }
    .profile-hero-content { position: relative; z-index: 1; }
    .profile-identity { display: flex; gap: 24px; align-items: center; }
    .profile-avatar { width: 96px; height: 96px; border-radius: 24px; background: rgba(255,255,255,.18); border: 1px solid rgba(255,255,255,.25); display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 24px rgba(0,0,0,.1), inset 0 1px 0 rgba(255,255,255,.2); flex-shrink: 0; backdrop-filter: blur(10px); }
    .profile-avatar i { width: 42px; height: 42px; }
    .profile-name-wrapper { flex-grow: 1; }
    .profile-kicker { display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; border-radius: 999px; background: rgba(255,255,255,.15); font-size: 0.75rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px; backdrop-filter: blur(10px); }
    .profile-name { margin: 0; font-size: 1.9rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1.1; }
    .profile-email { margin: 6px 0 0; opacity: 0.9; font-size: 0.95rem; }
    .hero-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 28px; }
    .hero-stat { background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.18); border-radius: 18px; padding: 16px; backdrop-filter: blur(10px); }
    .hero-stat-label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; opacity: 0.85; margin-bottom: 6px; }
    .hero-stat-value { font-size: 1.25rem; font-weight: 800; }
    .panel { background: var(--card); border: 1px solid var(--border); border-radius: 24px; padding: 26px; box-shadow: 0 10px 30px rgba(0,0,0,.05); transition: all 0.2s ease; margin-bottom: 24px; }
    .panel:hover { box-shadow: 0 14px 40px rgba(0,0,0,.08); }
    .panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .panel-title { margin: 0; font-size: 1.1rem; font-weight: 800; color: var(--text-main); letter-spacing: -0.01em; }
    .panel-subtitle { margin: 4px 0 0; color: var(--muted); font-size: 0.88rem; }
    .info-row { display: flex; justify-content: space-between; gap: 12px; padding: 14px 0; border-bottom: 1px solid var(--border); }
    .info-row:last-child { border-bottom: none; }
    .info-row .label { color: var(--muted); font-weight: 600; font-size: 0.9rem; }
    .info-row .value { color: var(--text-main); font-weight: 800; font-size: 0.95rem; }
    .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    .stat-box { padding: 16px; border-radius: 16px; background: var(--bg); border: 1px solid var(--border); text-align: center; transition: all 0.2s ease; }
    .stat-box:hover { border-color: var(--accent); background: var(--accent-soft); }
    .stat-box-number { font-size: 1.5rem; font-weight: 800; color: var(--text-main); line-height: 1; }
    .stat-box-label { font-size: 0.78rem; color: var(--muted); margin-top: 8px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
    .settings-list { display: flex; flex-direction: column; gap: 8px; }
    .settings-item { display: flex; align-items: center; gap: 12px; padding: 14px 16px; border-radius: 16px; color: var(--text-main); text-decoration: none; font-weight: 600; font-size: 0.95rem; transition: all 0.2s ease; border: 1px solid transparent; }
    .settings-item:hover { background: var(--bg); border-color: var(--border); color: var(--accent); }
    .settings-item i { width: 22px; height: 22px; color: var(--muted); }
    .settings-item:hover i { color: var(--accent); }
    
    /* Theme Toggle Switch */
    .toggle-wrapper { display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; border-radius: 16px; color: var(--text-main); text-decoration: none; font-weight: 600; font-size: 0.95rem; transition: all 0.2s ease; border: 1px solid transparent; }
    .toggle-wrapper:hover { background: var(--bg); border-color: var(--border); color: var(--accent); }
    .toggle-wrapper:hover i { color: var(--accent); }
    .toggle-left { display: flex; align-items: center; gap: 12px; }
    .toggle-left i { width: 22px; height: 22px; color: var(--muted); }
    .switch { position: relative; display: inline-block; width: 52px; height: 28px; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: var(--border); transition: .3s; border-radius: 28px; }
    .slider:before { position: absolute; content: ""; height: 22px; width: 22px; left: 3px; bottom: 3px; background-color: white; transition: .3s; border-radius: 50%; box-shadow: 0 2px 8px rgba(0,0,0,.15); }
    input:checked + .slider { background: linear-gradient(135deg, #0ea5e9, #10b981); }
    input:checked + .slider:before { transform: translateX(24px); }

    @@media (max-width: 767.98px) {
        .profile-topbar { margin-bottom: 18px; }
        .profile-hero { padding: 24px 18px; border-radius: 22px; }
        .profile-identity { gap: 16px; align-items: flex-start; }
        .profile-avatar { width: 72px; height: 72px; border-radius: 20px; }
        .profile-avatar i { width: 32px; height: 32px; }
        .profile-name { font-size: 1.45rem; }
        .hero-stats { grid-template-columns: repeat(2, 1fr); gap: 10px; margin-top: 20px; }
        .hero-stat { padding: 12px; border-radius: 14px; }
        .hero-stat-value { font-size: 1.1rem; }
        .panel { padding: 20px; border-radius: 20px; }
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
</style>

<div class="profile-page">
    <div class="profile-shell">
        <div class="profile-topbar">
            <a asp-controller="Expense" asp-action="Dashboard" class="back-link">
                <i data-lucide="arrow-left" style="width:18px;height:18px"></i>
                Back to Dashboard
            </a>
        </div>

        <div class="profile-hero">
            <div class="profile-hero-content">
                <div class="profile-identity">
                    <div class="profile-avatar">
                        <i data-lucide="user" style="width:42px;height:42px"></i>
                    </div>
                    <div class="profile-name-wrapper">
                        <div class="profile-kicker">
                            <i data-lucide="sparkles" style="width:14px;height:14px"></i>
                            Client Profile
                        </div>
                        <h1 class="profile-name">@Model.FullName</h1>
                        <p class="profile-email"><i data-lucide="mail" style="width:16px;height:16px;display:inline;margin-right:6px;opacity:.9"></i>@Model.Email</p>
                    </div>
                </div>

                <div class="hero-stats">
                    <div class="hero-stat">
                        <div class="hero-stat-label">Total Balance</div>
                        <div class="hero-stat-value">@Model.TotalBalance.ToString("C")</div>
                    </div>
                    <div class="hero-stat">
                        <div class="hero-stat-label">Total Income</div>
                        <div class="hero-stat-value">@Model.TotalIncome.ToString("C")</div>
                    </div>
                    <div class="hero-stat">
                        <div class="hero-stat-label">Total Expenses</div>
                        <div class="hero-stat-value">@Model.TotalExpense.ToString("C")</div>
                    </div>
                    <div class="hero-stat">
                        <div class="hero-stat-label">Member Since</div>
                        <div class="hero-stat-value">@Model.CreatedOn.ToString("MMM yyyy")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <div>
                    <h3 class="panel-title">Profile Information</h3>
                    <p class="panel-subtitle">Your personal details</p>
                </div>
            </div>
            <div class="info-row">
                <div class="label">Full Name</div>
                <div class="value">@Model.FullName</div>
            </div>
            <div class="info-row">
                <div class="label">Email Address</div>
                <div class="value">@Model.Email</div>
            </div>
            <div class="info-row">
                <div class="label">Member Since</div>
                <div class="value">@Model.CreatedOn.ToString("dd MMMM yyyy")</div>
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <div>
                    <h3 class="panel-title">Activity Stats</h3>
                    <p class="panel-subtitle">Your app usage</p>
                </div>
            </div>
            <div class="stats-grid">
                <div class="stat-box">
                    <div class="stat-box-number">@Model.AccountCount</div>
                    <div class="stat-box-label">Accounts</div>
                </div>
                <div class="stat-box">
                    <div class="stat-box-number">@Model.CategoryCount</div>
                    <div class="stat-box-label">Categories</div>
                </div>
                <div class="stat-box">
                    <div class="stat-box-number">@Model.ExpenseCount</div>
                    <div class="stat-box-label">Expenses</div>
                </div>
                <div class="stat-box">
                    <div class="stat-box-number">@Model.IncomeCount</div>
                    <div class="stat-box-label">Incomes</div>
                </div>
                <div class="stat-box">
                    <div class="stat-box-number">@Model.BudgetCount</div>
                    <div class="stat-box-label">Budgets</div>
                </div>
                <div class="stat-box">
                    <div class="stat-box-number">@Model.AutomationCount</div>
                    <div class="stat-box-label">Automations</div>
                </div>
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <div>
                    <h3 class="panel-title">Settings</h3>
                    <p class="panel-subtitle">Manage your account</p>
                </div>
            </div>
            <div class="settings-list">
                <a asp-action="Edit" class="settings-item">
                    <i data-lucide="user-cog"></i>
                    Edit Profile
                </a>
                <a asp-action="ChangePassword" class="settings-item">
                    <i data-lucide="key"></i>
                    Change Password
                </a>
                <div class="toggle-wrapper">
                    <div class="toggle-left">
                        <i data-lucide="sun-moon"></i>
                        Dark Mode
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="profileThemeToggle">
                        <span class="slider"></span>
                    </label>
                </div>
                <a asp-controller="Home" asp-action="Privacy" asp-route-source="profile" class="settings-item">
                    <i data-lucide="shield"></i>
                    Privacy & Security
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>$(function(){ lucide.createIcons(); });</script>
}
