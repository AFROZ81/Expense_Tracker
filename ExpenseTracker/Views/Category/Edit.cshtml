@model ExpenseTracker.Models.Entities.Category

@{
    ViewData["Title"] = "Edit Category";
}

<style>
    :root {
        --accent: #0ea5e9;
        --accent-hover: #0284c7;
        --accent-soft: rgba(14,165,233,0.08);
    }

    .form-page { animation: slideIn 0.45s ease-out; }
    @@keyframes slideIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

    /* ── Form Card ── */
    .form-card {
        background: var(--card); border: 1px solid var(--border);
        border-radius: 20px; overflow: hidden;
        box-shadow: 0 8px 30px rgba(0,0,0,0.06);
    }

    /* Card Header */
    .form-card-header {
        padding: 32px 36px; border-bottom: 1px solid var(--border);
        display: flex; align-items: center; gap: 18px;
    }
    .form-header-icon {
        width: 52px; height: 52px; border-radius: 16px; flex-shrink: 0;
        background: var(--accent-soft); color: var(--accent);
        display: flex; align-items: center; justify-content: center;
    }
    .form-card-header h2 { font-size: 1.2rem; font-weight: 800; color: var(--text-main); margin: 0; letter-spacing: -0.02em; }
    .form-card-header p { font-size: 0.82rem; color: var(--muted); margin: 3px 0 0; }

    /* Form Body */
    .form-card-body { padding: 32px 36px 36px; }

    /* ── Input Field ── */
    .field-group { margin-bottom: 24px; }
    .field-label {
        font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.08em; color: var(--muted); margin-bottom: 8px; display: block;
    }
    .input-wrap {
        display: flex; align-items: stretch;
        border: 1.5px solid var(--border); border-radius: 14px;
        background: var(--bg); transition: all 0.22s ease; overflow: hidden;
    }
    .input-wrap:focus-within {
        border-color: var(--accent); background: var(--card);
        box-shadow: 0 0 0 4px rgba(14,165,233,0.1);
    }
    .input-wrap-icon {
        width: 48px; min-width: 48px; display: flex;
        align-items: center; justify-content: center;
        color: var(--muted); flex-shrink: 0;
        border-right: 1.5px solid var(--border); transition: all 0.22s ease;
    }
    .input-wrap:focus-within .input-wrap-icon { color: var(--accent); border-right-color: var(--accent); }
    .input-wrap input {
        flex: 1; border: none; background: transparent; outline: none;
        padding: 13px 16px; font-size: 0.92rem; font-weight: 500;
        color: var(--text-main); min-width: 0;
    }
    .input-wrap input::placeholder { color: var(--muted); opacity: 0.6; }

    /* ── Toggle Section ── */
    .toggle-section {
        display: flex; justify-content: space-between; align-items: center;
        padding: 18px 20px; border-radius: 14px;
        background: var(--bg); border: 1px solid var(--border);
        margin-bottom: 32px; gap: 16px;
    }
    .toggle-section h6 { margin: 0; font-size: 0.9rem; font-weight: 700; color: var(--text-main); }
    .toggle-section p { margin: 0; font-size: 0.78rem; color: var(--muted); margin-top: 2px; }

    /* ── Buttons ── */
    .btn-submit {
        display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        background: var(--accent); color: white; border: none;
        padding: 13px 28px; border-radius: 12px; font-weight: 700; font-size: 0.9rem;
        transition: all 0.22s ease; box-shadow: 0 4px 16px rgba(14,165,233,0.2);
        cursor: pointer;
    }
    .btn-submit:hover { background: var(--accent-hover); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(14,165,233,0.3); }
    .btn-submit:active { transform: scale(0.97); }

    .btn-back-link {
        display: inline-flex; align-items: center; gap: 6px;
        color: var(--muted); font-weight: 600; font-size: 0.88rem;
        text-decoration: none; transition: all 0.2s ease;
    }
    .btn-back-link:hover { color: var(--text-main); }

    .form-actions {
        display: flex; justify-content: space-between; align-items: center;
    }

    /* ── Mobile ── */
    @@media (max-width: 767.98px) {
        .form-card { border-radius: 18px; }
        .form-card-header { padding: 22px 20px; gap: 14px; }
        .form-header-icon { width: 44px; height: 44px; border-radius: 12px; }
        .form-header-icon svg { width: 22px; height: 22px; }
        .form-card-header h2 { font-size: 1.1rem; }
        .form-card-header p { font-size: 0.78rem; }
        .form-card-body { padding: 22px 20px 28px; }
        .field-label { font-size: 0.68rem; margin-bottom: 6px; }
        .input-wrap { border-radius: 12px; }
        .input-wrap-icon { width: 44px; min-width: 44px; }
        .input-wrap-icon svg { width: 16px; height: 16px; }
        .input-wrap input { padding: 12px 14px; font-size: 0.88rem; min-height: 46px; }
        .toggle-section { padding: 14px 16px; border-radius: 12px; gap: 12px; }
        .toggle-section h6 { font-size: 0.85rem; }
        .toggle-section p { font-size: 0.74rem; }
        .form-check-input { width: 42px !important; height: 22px !important; }
        .form-actions { flex-direction: column-reverse; gap: 12px; align-items: stretch; }
        .btn-submit { width: 100%; padding: 14px 20px; border-radius: 12px; }
        .btn-back-link { justify-content: center; padding: 8px 0; }
    }
</style>

<div class="form-page">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-header-icon">
                        <i data-lucide="edit-3" style="width:24px;height:24px"></i>
                    </div>
                    <div>
                        <h2>Edit Category</h2>
                        <p>Update the details for this category.</p>
                    </div>
                </div>

                <div class="form-card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="field-group">
                            <label asp-for="Name" class="field-label">Category Name</label>
                            <div class="input-wrap">
                                <div class="input-wrap-icon">
                                    <i data-lucide="tag" style="width:18px;height:18px"></i>
                                </div>
                                <input asp-for="Name" placeholder="e.g. Health, Travel, Subscriptions" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="toggle-section">
                            <div>
                                <h6>Enable Category</h6>
                                <p>Set visibility status for this category across the app.</p>
                            </div>
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" style="cursor:pointer">
                            </div>
                        </div>

                        <div class="form-actions">
                            <a asp-action="Index" class="btn-back-link">
                                <i data-lucide="arrow-left" style="width:16px;height:16px"></i>
                                Back to categories
                            </a>
                            <button type="submit" class="btn-submit">
                                <i data-lucide="save" style="width:16px;height:16px"></i>
                                Update Category
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>$(function(){ lucide.createIcons(); });</script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
