@model ExpenseTracker.Models.Entities.Account

@{
    ViewData["Title"] = "Edit Account";
}

<style>
    :root { --accent:#f59e0b; --accent-hover:#d97706; --accent-soft:rgba(245,158,11,0.08); --danger:#ef4444; --danger-soft:rgba(239,68,68,0.08); }
    .form-page { animation:slideIn 0.45s ease-out; }
    @@keyframes slideIn { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }

    .form-card { background:var(--card); border:1px solid var(--border); border-radius:20px; overflow:hidden; box-shadow:0 8px 30px rgba(0,0,0,0.06); }
    .form-card-header { padding:28px 32px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:16px; }
    .form-header-icon { width:50px; height:50px; border-radius:16px; flex-shrink:0; background:var(--accent-soft); color:var(--accent); display:flex; align-items:center; justify-content:center; }
    .form-card-header h2 { font-size:1.15rem; font-weight:800; color:var(--text-main); margin:0; }
    .form-card-header p { font-size:0.8rem; color:var(--muted); margin:3px 0 0; }
    .form-card-body { padding:28px 32px 32px; }

    .field-group { margin-bottom:22px; }
    .field-label { font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--muted); margin-bottom:7px; display:block; }
    .field-hint { font-size:0.76rem; color:var(--muted); margin-top:6px; }

    .input-wrap { display:flex; align-items:stretch; border:1.5px solid var(--border); border-radius:14px; background:var(--bg); transition:all 0.22s; overflow:hidden; }
    .input-wrap:focus-within { border-color:var(--accent); background:var(--card); box-shadow:0 0 0 4px rgba(245,158,11,0.1); }
    .input-wrap-icon { width:46px; min-width:46px; display:flex; align-items:center; justify-content:center; color:var(--muted); flex-shrink:0; border-right:1.5px solid var(--border); transition:all 0.22s; }
    .input-wrap:focus-within .input-wrap-icon { color:var(--accent); border-right-color:var(--accent); }
    .input-wrap input, .input-wrap select { flex:1; border:none; background:transparent; outline:none; padding:12px 14px; font-size:0.9rem; font-weight:500; color:var(--text-main); min-width:0; appearance:none; font-family:inherit; }
    .input-wrap select { cursor:pointer; }
    .input-wrap input::placeholder { color:var(--muted); opacity:0.5; }

    .amount-wrap { display:flex; align-items:stretch; border:1.5px solid var(--border); border-radius:14px; background:var(--bg); transition:all 0.22s; overflow:hidden; }
    .amount-wrap:focus-within { border-color:var(--accent); background:var(--card); box-shadow:0 0 0 4px rgba(245,158,11,0.1); }
    .currency-prefix { width:46px; min-width:46px; display:flex; align-items:center; justify-content:center; font-weight:800; color:var(--muted); font-size:1.1rem; border-right:1.5px solid var(--border); flex-shrink:0; transition:all 0.22s; }
    .amount-wrap:focus-within .currency-prefix { color:var(--accent); border-right-color:var(--accent); }
    .amount-wrap input { flex:1; border:none; background:transparent; outline:none; padding:14px 16px; font-size:1.2rem; font-weight:800; color:var(--text-main); min-width:0; font-family:inherit; }
    .amount-wrap input::placeholder { color:var(--muted); opacity:0.4; }

    /* Toggle */
    .toggle-section { display:flex; justify-content:space-between; align-items:center; padding:16px 20px; border-radius:14px; background:var(--bg); border:1px solid var(--border); margin-bottom:24px; gap:14px; }
    .toggle-section h6 { margin:0; font-size:0.88rem; font-weight:700; color:var(--text-main); }
    .toggle-section p { margin:0; font-size:0.76rem; color:var(--muted); margin-top:2px; }

    .btn-submit { display:inline-flex; align-items:center; justify-content:center; gap:8px; background:var(--accent); color:white; border:none; padding:14px 28px; border-radius:12px; font-weight:700; font-size:0.9rem; width:100%; transition:all 0.22s; box-shadow:0 4px 16px rgba(245,158,11,0.25); cursor:pointer; font-family:inherit; }
    .btn-submit:hover { background:var(--accent-hover); transform:translateY(-1px); box-shadow:0 8px 24px rgba(245,158,11,0.35); }

    .btn-back-link { display:inline-flex; align-items:center; gap:6px; color:var(--muted); font-weight:600; font-size:0.88rem; text-decoration:none; transition:all 0.2s; margin-bottom:18px; }
    .btn-back-link:hover { color:var(--text-main); }

    /* Danger zone */
    .danger-zone { margin-top:24px; padding-top:20px; border-top:1px solid var(--border); text-align:center; }
    .btn-danger-link { display:inline-flex; align-items:center; gap:6px; color:var(--danger); font-weight:700; font-size:0.84rem; text-decoration:none; transition:all 0.2s; padding:8px 16px; border-radius:10px; }
    .btn-danger-link:hover { background:var(--danger-soft); color:#dc2626; }

    /* Modal */
    .del-modal .modal-content { border-radius:24px; border:none; box-shadow:0 30px 80px rgba(0,0,0,0.18); background:var(--card); }
    .del-modal-icon { width:68px; height:68px; border-radius:50%; background:var(--danger-soft); color:var(--danger); display:flex; align-items:center; justify-content:center; margin:0 auto 18px; }
    .modal-btn-del { background:var(--danger); color:white; border:none; padding:12px 28px; border-radius:12px; font-weight:700; transition:all 0.2s; text-decoration:none; }
    .modal-btn-del:hover { background:#dc2626; transform:translateY(-1px); box-shadow:0 8px 20px rgba(239,68,68,0.25); color:white; }
    .modal-btn-cancel { background:var(--bg); color:var(--muted); border:1px solid var(--border); padding:12px 28px; border-radius:12px; font-weight:700; transition:all 0.2s; }
    .modal-btn-cancel:hover { background:var(--border); color:var(--text-main); }

    @@media (max-width:767.98px) {
        .form-card { border-radius:18px; }
        .form-card-header { padding:20px 18px; gap:12px; }
        .form-header-icon { width:44px; height:44px; border-radius:12px; }
        .form-header-icon svg { width:22px; height:22px; }
        .form-card-header h2 { font-size:1.05rem; }
        .form-card-body { padding:20px 18px 26px; }
        .field-group { margin-bottom:18px; }
        .field-label { font-size:0.66rem; margin-bottom:5px; }
        .input-wrap { border-radius:12px; }
        .input-wrap-icon { width:42px; min-width:42px; }
        .input-wrap-icon svg { width:16px; height:16px; }
        .input-wrap input, .input-wrap select { padding:11px 12px; font-size:0.86rem; }
        .amount-wrap { border-radius:12px; }
        .currency-prefix { width:42px; min-width:42px; font-size:1rem; }
        .amount-wrap input { padding:12px 14px; font-size:1.1rem; }
        .toggle-section { padding:14px 16px; border-radius:12px; gap:12px; }
        .toggle-section h6 { font-size:0.84rem; }
        .toggle-section p { font-size:0.72rem; }
        .form-check-input { width:42px !important; height:22px !important; }
        .btn-submit { padding:14px 20px; }
    }
</style>

<div class="form-page">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <a asp-action="Index" class="btn-back-link">
                <i data-lucide="arrow-left" style="width:16px;height:16px"></i> Back to accounts
            </a>

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-header-icon">
                        <i data-lucide="edit-3" style="width:24px;height:24px"></i>
                    </div>
                    <div>
                        <h2>Edit Account</h2>
                        <p>Update details for @Model.Name</p>
                    </div>
                </div>

                <div class="form-card-body">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CurrentBalance" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="field-group">
                            <label asp-for="Name" class="field-label">Account Name</label>
                            <div class="input-wrap">
                                <div class="input-wrap-icon"><i data-lucide="user" style="width:17px;height:17px"></i></div>
                                <input asp-for="Name" placeholder="e.g. HDFC Savings, Wallet Cash" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="field-group">
                            <label asp-for="Type" class="field-label">Account Type</label>
                            <div class="input-wrap">
                                <div class="input-wrap-icon"><i data-lucide="layers" style="width:17px;height:17px"></i></div>
                                <select asp-for="Type" asp-items="Html.GetEnumSelectList<ExpenseTracker.Models.Entities.AccountType>()"></select>
                            </div>
                            <span asp-validation-for="Type" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="field-group">
                            <label asp-for="InitialBalance" class="field-label">Starting Balance</label>
                            <div class="amount-wrap">
                                <span class="currency-prefix">₹</span>
                                <input asp-for="InitialBalance" type="number" step="0.01" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="InitialBalance" class="text-danger small mt-1 d-block"></span>
                            <p class="field-hint">Adjusting this will shift the current balance by the same difference.</p>
                        </div>

                        <div class="toggle-section">
                            <div>
                                <h6>Active Status</h6>
                                <p>Toggle whether this account is visible and usable.</p>
                            </div>
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" style="cursor:pointer">
                            </div>
                        </div>

                        <button type="submit" class="btn-submit">
                            <i data-lucide="save" style="width:16px;height:16px"></i> Save Changes
                        </button>
                    </form>

                    <div class="danger-zone">
                        <a href="#" class="btn-danger-link" id="deleteAccountTrigger" data-id="@Model.Id">
                            <i data-lucide="trash-2" style="width:14px;height:14px"></i> Permanently Delete Account
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade del-modal" id="deleteAccountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px">
        <div class="modal-content">
            <div class="modal-body p-5 text-center">
                <div class="del-modal-icon"><i data-lucide="trash-2" style="width:28px;height:28px"></i></div>
                <h4 class="fw-800 text-main-adaptive mb-2" style="font-size:1.15rem">Delete Account?</h4>
                <p class="text-muted mb-4" style="font-size:0.88rem">This account must have no linked transactions. This action cannot be undone.</p>
                <div class="d-flex gap-3 justify-content-center">
                    <button type="button" class="modal-btn-cancel flex-grow-1" data-bs-dismiss="modal">Cancel</button>
                    <a id="confirmDeleteAccountBtn" href="#" class="modal-btn-del flex-grow-1 text-decoration-none text-center">Delete</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(function() {
            lucide.createIcons();
            $('#deleteAccountTrigger').on('click', function(e) {
                e.preventDefault();
                $('#confirmDeleteAccountBtn').attr('href', `/Wallet/Delete/${$(this).data('id')}`);
                new bootstrap.Modal(document.getElementById('deleteAccountModal')).show();
            });
        });
    </script>
}
