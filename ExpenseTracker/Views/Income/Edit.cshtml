@model ExpenseTracker.Models.Entities.Income

@{
    ViewData["Title"] = "Edit Income";
}

<style>
    :root {
        --accent: #10b981;
        --card-radius: 24px;
    }

    .form-container {
        animation: fadeIn 0.5s ease-out;
        max-width: 800px;
        margin: 0 auto;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .premium-card {
        background: var(--card);
        border-radius: var(--card-radius);
        border: 1px solid rgba(0,0,0,0.03);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        padding: 40px;
    }

    .form-label {
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--muted);
        margin-bottom: 10px;
    }

    .form-control, .form-select {
        border-radius: 14px;
        padding: 12px 20px;
        border: 1px solid var(--border);
        transition: all 0.2s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
    }

    .btn-submit {
        background: var(--accent);
        color: white;
        border: none;
        padding: 14px;
        border-radius: 14px;
        font-weight: 700;
        transition: all 0.2s ease;
        width: 100%;
    }

    .btn-submit:hover {
        background: #059669;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);
        color: white;
    }

    .input-group-text {
        border-radius: 14px 0 0 14px;
        background: var(--bg);
        border: 1px solid var(--border);
        color: var(--muted);
        font-weight: 700;
    }

    .input-group .form-control {
        border-radius: 0 14px 14px 0;
    }
</style>

<div class="form-container">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Index" class="btn btn-light rounded-circle p-2 d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px">
            <i data-lucide="arrow-left" style="width: 20px; color: var(--muted);"></i>
        </a>
        <h1 class="h3 fw-800 text-main-adaptive m-0">Edit Income Record</h1>
    </div>

    <div class="premium-card">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <label asp-for="IncomeCategoryId" class="form-label">Income Source</label>
                    <select asp-for="IncomeCategoryId" class="form-select" asp-items="ViewBag.IncomeCategoryList">
                        <option value="">-- Select Source --</option>
                    </select>
                    <span asp-validation-for="IncomeCategoryId" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-4">
                    <label asp-for="AccountId" class="form-label">Deposit Account</label>
                    <select asp-for="AccountId" class="form-select" asp-items="ViewBag.AccountList">
                        <option value="">-- Select Account --</option>
                    </select>
                    <span asp-validation-for="AccountId" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Amount" class="form-label">Amount</label>
                <div class="input-group">
                    <span class="input-group-text">₹</span>
                    <input asp-for="Amount" class="form-control" type="number" step="0.01" placeholder="0.00" />
                </div>
                <span asp-validation-for="Amount" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="IncomeDate" class="form-label">Date received</label>
                <input asp-for="IncomeDate" class="form-control" type="date" value="@Model.IncomeDate.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="IncomeDate" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label">Description (Optional)</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Add some notes about this income..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-submit mt-2">
                Update Income Record
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(function() {
            lucide.createIcons();
        });
    </script>
}

