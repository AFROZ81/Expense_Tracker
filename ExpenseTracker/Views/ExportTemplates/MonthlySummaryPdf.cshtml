@model ExpenseTracker.Models.ViewModels.Exports.MonthlySummaryReportExportViewModel
@{
    Layout = null;
}
<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <style>
        * { box-sizing: border-box; }
        body { font-family: "Segoe UI", Arial, sans-serif; margin: 0; color: #0f172a; }
        .report { padding: 24px 10px; }
        .header { border-bottom: 2px solid #4f46e5; padding-bottom: 14px; margin-bottom: 16px; }
        .title { margin: 0; font-size: 24px; font-weight: 700; color: #1e1b4b; }
        .meta { margin-top: 8px; color: #475569; font-size: 12px; }
        .summary-box { margin: 14px 0; background: #eef2ff; border: 1px solid #c7d2fe; border-radius: 8px; padding: 12px; }
        .summary-label { font-size: 11px; text-transform: uppercase; color: #4338ca; }
        .summary-value { font-size: 22px; font-weight: 700; margin-top: 4px; color: #1e1b4b; }
        table { width: 100%; border-collapse: collapse; }
        thead { display: table-header-group; }
        th { text-align: left; background: #f1f5f9; color: #334155; padding: 10px; font-size: 11px; text-transform: uppercase; }
        td { border-bottom: 1px solid #e2e8f0; padding: 10px; font-size: 12px; }
        .num { text-align: right; white-space: nowrap; }
        .footer { margin-top: 14px; font-size: 11px; color: #64748b; }
    </style>
</head>
<body>
    <div class="report">
        <div class="header">
            <h1 class="title">@Model.ReportTitle</h1>
            <div class="meta">
                Statement: @Model.MonthName @Model.Year<br />
                Generated for: @Model.GeneratedFor<br />
                Generated on: @Model.GeneratedOn.ToString("dd MMM yyyy, hh:mm tt")
            </div>
        </div>

        <div class="summary-box">
            <div class="summary-label">Total Monthly Expense</div>
            <div class="summary-value">Rs. @Model.TotalAmount.ToString("N2")</div>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Category</th>
                    <th class="num">Amount</th>
                    <th class="num">Share</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="3">No data available for this month.</td>
                    </tr>
                }
                else
                {
                    foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td>@row.CategoryName</td>
                            <td class="num">Rs. @row.Amount.ToString("N2")</td>
                            <td class="num">@row.Percentage.ToString("N2")%</td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <div class="footer">
            ExpenseTracker Export
        </div>
    </div>
</body>
</html>
