@model ExpenseTracker.Models.ViewModels.Exports.ExpenseReportExportViewModel
@{
    Layout = null;
}
<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <style>
        * { box-sizing: border-box; }
        body { font-family: "Segoe UI", Arial, sans-serif; margin: 0; color: #0f172a; }
        .report { padding: 24px 10px; }
        .header { border-bottom: 2px solid #4f46e5; padding-bottom: 14px; margin-bottom: 16px; }
        .title { margin: 0; font-size: 24px; font-weight: 700; color: #1e1b4b; }
        .meta { margin-top: 8px; color: #475569; font-size: 12px; }
        .kpis { display: flex; gap: 12px; margin-bottom: 16px; }
        .kpi { flex: 1; border: 1px solid #e2e8f0; border-radius: 8px; padding: 10px 12px; background: #f8fafc; }
        .kpi .label { font-size: 11px; color: #64748b; text-transform: uppercase; }
        .kpi .value { margin-top: 4px; font-size: 18px; font-weight: 700; }
        table { width: 100%; border-collapse: collapse; }
        thead { display: table-header-group; }
        th { text-align: left; background: #eef2ff; color: #3730a3; padding: 10px; font-size: 11px; text-transform: uppercase; }
        td { border-bottom: 1px solid #e2e8f0; padding: 10px; font-size: 12px; vertical-align: top; }
        .num { text-align: right; white-space: nowrap; }
        .footer { margin-top: 14px; font-size: 11px; color: #64748b; }
    </style>
</head>
<body>
    <div class="report">
        <div class="header">
            <h1 class="title">@Model.ReportTitle</h1>
            <div class="meta">
                Generated for: @Model.GeneratedFor<br />
                Generated on: @Model.GeneratedOn.ToString("dd MMM yyyy, hh:mm tt")
            </div>
        </div>

        <div class="kpis">
            <div class="kpi">
                <div class="label">Total Records</div>
                <div class="value">@Model.TotalRecords</div>
            </div>
            <div class="kpi">
                <div class="label">Total Expense</div>
                <div class="value">Rs. @Model.TotalAmount.ToString("N2")</div>
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Category</th>
                    <th>Account</th>
                    <th>Description</th>
                    <th class="num">Amount</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="5">No transactions found.</td>
                    </tr>
                }
                else
                {
                    foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td>@row.ExpenseDate.ToString("dd MMM yyyy")</td>
                            <td>@row.CategoryName</td>
                            <td>@row.AccountName</td>
                            <td>@row.Description</td>
                            <td class="num">Rs. @row.Amount.ToString("N2")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <div class="footer">
            ExpenseTracker Export
        </div>
    </div>
</body>
</html>
