@model IEnumerable<ExpenseTracker.Models.Entities.IncomeCategory>

@{
    ViewData["Title"] = "Income Categories";
}

<style>
    :root { --accent:#10b981; --accent-hover:#059669; --accent-soft:rgba(16,185,129,0.08); --danger:#ef4444; --danger-soft:rgba(239,68,68,0.08); }
    .ic-page { animation:pageIn 0.45s ease-out; }
    @@keyframes pageIn { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
    @@keyframes cardIn { from{opacity:0;transform:translateY(10px) scale(0.98)} to{opacity:1;transform:translateY(0) scale(1)} }

    /* Header */
    .ic-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; gap:16px; flex-wrap:wrap; }
    .ic-header h1 { font-size:1.35rem; font-weight:800; color:var(--text-main); margin:0; letter-spacing:-0.02em; }
    .ic-header p { font-size:0.84rem; color:var(--muted); margin:4px 0 0; }
    .btn-add { display:inline-flex; align-items:center; gap:8px; background:var(--accent); color:white; border:none; padding:11px 24px; border-radius:12px; font-weight:700; font-size:0.88rem; text-decoration:none; transition:all 0.22s; box-shadow:0 4px 16px rgba(16,185,129,0.2); }
    .btn-add:hover { background:var(--accent-hover); transform:translateY(-1px); box-shadow:0 8px 24px rgba(16,185,129,0.3); color:white; }

    /* Stats */
    .ic-stats { display:flex; gap:10px; margin-bottom:20px; flex-wrap:wrap; }
    .ic-stat-chip { display:inline-flex; align-items:center; gap:8px; padding:7px 14px; border-radius:10px; font-size:0.76rem; font-weight:700; background:var(--card); border:1px solid var(--border); }
    .ic-stat-chip .dot { width:8px; height:8px; border-radius:50%; }
    .dot.green { background:var(--accent); box-shadow:0 0 8px rgba(16,185,129,0.4); }
    .dot.gray { background:var(--muted); }

    /* Card Grid */
    .ic-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(300px,1fr)); gap:14px; }

    /* Category Card */
    .ic-card {
        background:var(--card); border:1px solid var(--border); border-radius:16px; padding:18px 20px;
        display:flex; align-items:center; gap:14px; transition:all 0.22s;
        animation:cardIn 0.35s ease-out both; position:relative; overflow:hidden;
    }
    .ic-card::before { content:''; position:absolute; left:0; top:0; bottom:0; width:3px; border-radius:3px 0 0 3px; background:var(--accent); opacity:0; transition:opacity 0.22s; }
    .ic-card:hover { border-color:rgba(16,185,129,0.2); box-shadow:0 6px 20px rgba(0,0,0,0.05); transform:translateY(-2px); }
    .ic-card:hover::before { opacity:1; }
    .ic-card:nth-child(1){animation-delay:.03s} .ic-card:nth-child(2){animation-delay:.06s} .ic-card:nth-child(3){animation-delay:.09s}
    .ic-card:nth-child(4){animation-delay:.12s} .ic-card:nth-child(5){animation-delay:.15s} .ic-card:nth-child(6){animation-delay:.18s}

    .ic-card-icon { width:44px; height:44px; border-radius:12px; background:var(--accent-soft); color:var(--accent); display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:all 0.22s; }
    .ic-card:hover .ic-card-icon { background:var(--accent); color:white; }

    .ic-card-body { flex:1; min-width:0; }
    .ic-card-name { font-size:0.95rem; font-weight:700; color:var(--text-main); margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .ic-card-meta { font-size:0.72rem; color:var(--muted); margin-top:3px; display:flex; align-items:center; gap:6px; }

    .status-dot-label { display:inline-flex; align-items:center; gap:5px; font-size:0.7rem; font-weight:600; }
    .status-dot-label .dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
    .status-dot-label.active .dot { background:#22c55e; box-shadow:0 0 6px rgba(34,197,94,0.5); }
    .status-dot-label.active { color:#16a34a; }
    .status-dot-label.inactive .dot { background:var(--muted); }
    .status-dot-label.inactive { color:var(--muted); }
    [data-theme="dark"] .status-dot-label.active { color:#4ade80; }
    [data-theme="dark"] .status-dot-label.inactive { color:#94a3b8; }

    .ic-card-actions { display:flex; gap:5px; flex-shrink:0; }
    .act-btn { width:36px; height:36px; border-radius:10px; border:1px solid var(--border); background:var(--card); color:var(--muted); cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all 0.2s; text-decoration:none; }
    .act-btn:hover { transform:translateY(-1px); }
    .act-btn.edit:hover { background:var(--accent-soft); color:var(--accent); border-color:rgba(16,185,129,0.25); }
    .act-btn.delete:hover { background:var(--danger-soft); color:var(--danger); border-color:rgba(239,68,68,0.2); }

    /* Empty */
    .empty-card { grid-column:1/-1; text-align:center; padding:56px 24px; background:var(--card); border:1px dashed var(--border); border-radius:20px; }
    .empty-icon { width:72px; height:72px; border-radius:20px; background:var(--accent-soft); color:var(--accent); display:flex; align-items:center; justify-content:center; margin:0 auto 18px; }
    .empty-card h5 { font-size:1.05rem; font-weight:800; color:var(--text-main); margin:0 0 6px; }
    .empty-card p { font-size:0.84rem; color:var(--muted); margin:0 0 20px; }

    /* Modal */
    .del-modal .modal-content { border-radius:24px; border:none; box-shadow:0 30px 80px rgba(0,0,0,0.18); background:var(--card); }
    .del-modal-icon { width:68px; height:68px; border-radius:50%; background:var(--danger-soft); color:var(--danger); display:flex; align-items:center; justify-content:center; margin:0 auto 18px; }
    .modal-btn-del { background:var(--danger); color:white; border:none; padding:12px 28px; border-radius:12px; font-weight:700; transition:all 0.2s; text-decoration:none; }
    .modal-btn-del:hover { background:#dc2626; transform:translateY(-1px); box-shadow:0 8px 20px rgba(239,68,68,0.25); color:white; }
    .modal-btn-cancel { background:var(--bg); color:var(--muted); border:1px solid var(--border); padding:12px 28px; border-radius:12px; font-weight:700; transition:all 0.2s; }
    .modal-btn-cancel:hover { background:var(--border); color:var(--text-main); }

    @@media (max-width:767.98px) {
        .ic-header { flex-direction:column; align-items:stretch; margin-bottom:18px; }
        .ic-header h1 { font-size:1.2rem; }
        .btn-add { justify-content:center; padding:13px 20px; }
        .ic-grid { grid-template-columns:1fr; gap:10px; }
        .ic-card { padding:14px 16px; gap:12px; border-radius:14px; }
        .ic-card-icon { width:40px; height:40px; border-radius:10px; }
        .ic-card-icon svg { width:18px; height:18px; }
        .ic-card-name { font-size:0.9rem; }
        .act-btn { width:38px; height:38px; }
        .empty-card { padding:40px 16px; }
    }
    @@media (max-width:400px) { .ic-card-actions { flex-direction:column; gap:4px; } }
</style>

<div class="ic-page">
    <div class="ic-header">
        <div>
            <h1>Income Categories</h1>
            <p>Organize your income sources (Salary, Freelance, etc.).</p>
        </div>
        <a asp-action="Create" class="btn-add"><i data-lucide="plus" style="width:18px;height:18px"></i> New Category</a>
    </div>

    @if (Model.Any())
    {
        var activeCount = Model.Count(c => c.IsActive);
        <div class="ic-stats">
            <span class="ic-stat-chip"><span class="dot green"></span> @Model.Count() Total</span>
            <span class="ic-stat-chip"><span class="dot green"></span> @activeCount Active</span>
            <span class="ic-stat-chip"><span class="dot gray"></span> @(Model.Count() - activeCount) Inactive</span>
        </div>
    }

    <div class="ic-grid">
        @if (!Model.Any())
        {
            <div class="empty-card">
                <div class="empty-icon"><i data-lucide="briefcase" style="width:28px;height:28px"></i></div>
                <h5>No Income Sources Yet</h5>
                <p>Create your first income category to start tracking earnings.</p>
                <a asp-action="Create" class="btn-add"><i data-lucide="plus" style="width:18px;height:18px"></i> Create Category</a>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                <div class="ic-card">
                    <div class="ic-card-icon">
                        <i data-lucide="wallet" style="width:18px;height:18px"></i>
                    </div>
                    <div class="ic-card-body">
                        <p class="ic-card-name">@item.Name</p>
                        <div class="ic-card-meta">
                            @if (item.IsActive)
                            {
                                <span class="status-dot-label active"><span class="dot"></span> Active</span>
                            }
                            else
                            {
                                <span class="status-dot-label inactive"><span class="dot"></span> Inactive</span>
                            }
                        </div>
                    </div>
                    <div class="ic-card-actions">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="act-btn edit" title="Edit">
                            <i data-lucide="pencil" style="width:15px;height:15px"></i>
                        </a>
                        <button type="button" class="act-btn delete delete-trigger"
                                data-id="@item.Id" data-name="@item.Name" title="Delete">
                            <i data-lucide="trash-2" style="width:15px;height:15px"></i>
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>

<div class="modal fade del-modal" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px">
        <div class="modal-content">
            <div class="modal-body p-5 text-center">
                <div class="del-modal-icon"><i data-lucide="alert-triangle" style="width:28px;height:28px"></i></div>
                <h4 class="fw-800 text-main-adaptive mb-2" style="font-size:1.15rem">Delete Category?</h4>
                <p class="text-muted mb-4" style="font-size:0.88rem">Are you sure you want to delete <strong id="deleteTargetName" class="text-main-adaptive"></strong>? This can't be undone.</p>
                <div class="d-flex gap-3 justify-content-center">
                    <button type="button" class="modal-btn-cancel flex-grow-1" data-bs-dismiss="modal">Cancel</button>
                    <a id="confirmDeleteBtn" href="#" class="modal-btn-del flex-grow-1 text-decoration-none text-center">Delete</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            lucide.createIcons();
            $('.delete-trigger').on('click', function() {
                const id = $(this).data('id');
                const name = $(this).data('name');
                $('#deleteTargetName').text(name);
                $('#confirmDeleteBtn').attr('href', `/IncomeCategory/Delete/${id}`);
                new bootstrap.Modal(document.getElementById('deleteConfirmModal')).show();
            });
        });
    </script>
}
