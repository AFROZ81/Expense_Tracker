@model ExpenseTracker.Models.Entities.IncomeCategory

@{
    ViewData["Title"] = "Edit Income Category";
}

<style>
    :root {
        --accent: #10b981;
        --card-radius: 24px;
    }

    .form-container {
        animation: fadeIn 0.5s ease-out;
        max-width: 600px;
        margin: 0 auto;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .premium-card {
        background: var(--card);
        border-radius: var(--card-radius);
        border: 1px solid rgba(0,0,0,0.03);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        padding: 40px;
    }

    .form-label {
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--muted);
        margin-bottom: 10px;
    }

    .form-control {
        border-radius: 14px;
        padding: 12px 20px;
        border: 1px solid var(--border);
        transition: all 0.2s ease;
    }

    .form-control:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
    }

    .btn-submit {
        background: var(--accent);
        color: white;
        border: none;
        padding: 14px;
        border-radius: 14px;
        font-weight: 700;
        transition: all 0.2s ease;
        width: 100%;
    }

    .btn-submit:hover {
        background: #059669;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);
        color: white;
    }
</style>

<div class="form-container">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Index" class="btn btn-light rounded-circle p-2 d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px">
            <i data-lucide="arrow-left" style="width: 20px; color: var(--muted);"></i>
        </a>
        <h1 class="h3 fw-800 text-main-adaptive m-0">Edit Category</h1>
    </div>

    <div class="premium-card">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="mb-4">
                <label asp-for="Name" class="form-label">Category Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Salary, Freelance, Bonus" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-4 d-flex align-items-center gap-2">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" asp-for="IsActive">
                    <label class="form-check-label fw-600 text-main-adaptive" asp-for="IsActive">Is Active?</label>
                </div>
            </div>

            <button type="submit" class="btn-submit mt-2">
                Update Income Category
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(function() {
            lucide.createIcons();
        });
    </script>
}

