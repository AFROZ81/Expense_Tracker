@model IEnumerable<ExpenseTracker.Models.ViewModels.MonthlySummaryViewModel>
@using System.Globalization

@{
    ViewData["Title"] = "Monthly Summary";
    int selectedMonth = ViewBag.Month;
    int selectedYear = ViewBag.Year;
    decimal grandTotal = Model.Any() ? Model.Sum(x => x.TotalAmount) : 0;
}

<style>
    :root {
        --accent: #6366f1;
        --accent-soft: rgba(99, 102, 241, 0.08);
        --card-radius: 24px;
    }

    .summary-page-wrapper {
        animation: fadeIn 0.6s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Hero Summary Card */
    .summary-hero-card {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        border-radius: 30px;
        padding: 40px;
        color: white;
        margin-bottom: 32px;
        box-shadow: 0 20px 40px rgba(79, 70, 229, 0.2);
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }

    .summary-hero-card::after {
        content: '';
        position: absolute;
        width: 300px;
        height: 300px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        top: -150px;
        right: -100px;
    }

    .hero-amount {
        font-size: 3rem;
        font-weight: 800;
        letter-spacing: -0.04em;
        margin-top: 8px;
    }

    /* Filter Panel */
    .filter-panel {
        background: var(--card);
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        margin-bottom: 32px;
        border: 1px solid var(--border);
    }

    .modern-select {
        background: var(--bg);
        border: 1.5px solid var(--border);
        border-radius: 14px;
        padding: 12px 16px 12px 45px;
        font-weight: 600;
        color: var(--text-main);
        appearance: none;
        width: 100%;
        transition: all 0.2s ease;
    }

    .modern-select:focus {
        border-color: var(--accent);
        background: var(--card);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        outline: none;
    }

    .btn-apply {
        background: var(--accent);
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 14px;
        font-weight: 700;
        width: 100%;
        transition: all 0.3s ease;
    }

    .btn-apply:hover {
        background: #4f46e5;
        transform: translateY(-2px);
        box-shadow: 0 8px 15px rgba(99, 102, 241, 0.3);
    }

    /* Distribution Table */
    .analysis-card {
        background: var(--card);
        border-radius: 30px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        border: 1px solid var(--border);
    }

    .modern-analysis-table th {
        background: var(--bg);
        padding: 18px 24px;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--muted);
        border: none;
    }

    .modern-analysis-table td {
        padding: 24px;
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
    }

    .progress-wrapper {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .progress-bar-bg {
        height: 10px;
        background: var(--border);
        border-radius: 10px;
        flex: 1;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--accent) 0%, #818cf8 100%);
        border-radius: 10px;
        transition: width 1s cubic-bezier(0.17, 0.67, 0.83, 0.67);
    }
</style>

<div class="summary-page-wrapper" id="monthlySummaryReport">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
        <div>
            <h1 class="h3 fw-800 text-main-adaptive m-0">Monthly Report</h1>
            <p class="text-muted small m-0">In-depth analysis of your spending for @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(selectedMonth) @selectedYear</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-light rounded-pill px-4 py-2 fw-bold shadow-sm border" href="@Url.Action("MonthlySummaryExcel", "Export", new { month = selectedMonth, year = selectedYear })">
                <i data-lucide="sheet" class="me-2" style="width: 18px"></i> Download Excel
            </a>
        </div>
    </div>

    <!-- Hero Card -->
    <div class="summary-hero-card">
        <div>
            <span class="text-white-50 fw-700 text-uppercase small letter-spacing-1">Monthly Total Expenditure</span>
            <div class="hero-amount">₹ @grandTotal.ToString("N0")</div>
            <div class="mt-3 d-flex align-items-center gap-2">
                <span class="badge bg-white bg-opacity-20 rounded-pill px-3 py-2 fw-600">
                    <i data-lucide="calendar-days" style="width: 14px" class="me-1"></i>
                    @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(selectedMonth) Statement
                </span>
            </div>
        </div>
        <div class="hero-icon-large d-none d-md-block">
            <i data-lucide="pie-chart" style="width: 80px; height: 80px; opacity: 0.3"></i>
        </div>
    </div>

    <!-- Filters -->
    <div class="filter-panel">
        <form method="get" asp-action="MonthlySummary" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="modern-label mb-2 d-block small fw-800 text-muted text-uppercase">Statement Month</label>
                <div class="position-relative">
                    <i data-lucide="calendar" class="position-absolute translate-middle-y top-50 start-0 ms-3 text-muted" style="width: 18px"></i>
                    <select name="month" class="modern-select">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" selected="@(m == selectedMonth)">
                                @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)
                            </option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-4">
                <label class="modern-label mb-2 d-block small fw-800 text-muted text-uppercase">Accounting Year</label>
                <div class="position-relative">
                    <i data-lucide="hash" class="position-absolute translate-middle-y top-50 start-0 ms-3 text-muted" style="width: 18px"></i>
                    <select name="year" class="modern-select">
                        @for (int y = DateTime.Now.Year - 5; y <= DateTime.Now.Year + 1; y++)
                        {
                            <option value="@y" selected="@(y == selectedYear)">@y</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn-apply shadow-sm">
                    <i data-lucide="refresh-cw" class="me-2" style="width: 16px"></i> Update View
                </button>
            </div>
        </form>
    </div>

    <!-- Data Table -->
    <div class="analysis-card">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-800 m-0">Spending Distribution</h5>
            <span class="text-muted small fw-600">Calculated across @Model.Count() Categories</span>
        </div>

        <div class="table-responsive">
            <table class="table modern-analysis-table align-middle">
                <thead>
                    <tr>
                        <th style="width: 35%">Category</th>
                        <th style="width: 40%">Usage Intensity</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5">
                                <i data-lucide="layers" style="width: 48px; height: 48px; color: #cbd5e1" class="mb-3"></i>
                                <h6 class="fw-bold">No Data Available</h6>
                                <p class="text-muted small">Try selecting a different month or year.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var percent = grandTotal > 0 ? (int)((item.TotalAmount / grandTotal) * 100) : 0;
                            <tr>
                                <td>
                                    <span class="fw-700 text-main-adaptive">@item.CategoryName</span>
                                </td>
                                <td>
                                    <div class="progress-wrapper">
                                        <div class="progress-bar-bg">
                                            <div class="progress-bar-fill" style="width: 0%" data-width="@percent%"></div>
                                        </div>
                                        <span class="fw-700 text-muted small" style="min-width: 35px">@percent%</span>
                                    </div>
                                </td>
                                <td class="text-end">
                                    <span class="fw-800 text-main-adaptive">₹ @item.TotalAmount.ToString("N0")</span>
                                </td>
                            </tr>
                        }
                        <tr class="bg-light bg-opacity-50">
                            <td class="fw-800 text-uppercase small text-muted">Total Monthly Expense</td>
                            <td></td>
                            <td class="text-end fw-900 text-indigo-600 h5 m-0">₹ @grandTotal.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            lucide.createIcons();
            
            // Animate bars
            setTimeout(() => {
                $('.progress-bar-fill').each(function() {
                    $(this).css('width', $(this).data('width'));
                });
            }, 300);
        });
    </script>
}
