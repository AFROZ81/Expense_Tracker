@model IEnumerable<ExpenseTracker.Models.ViewModels.MonthlySummaryViewModel>
@using System.Globalization

@{
    ViewData["Title"] = "Monthly Summary";
    int selectedMonth = ViewBag.Month;
    int selectedYear = ViewBag.Year;
    decimal grandTotal = Model.Any() ? Model.Sum(x => x.TotalAmount) : 0;
}

<style>
    :root { --accent:#0ea5e9; --accent-hover:#0284c7; --accent-soft:rgba(14,165,233,0.08); }
    .ms-page { animation:pageIn 0.45s ease-out; }
    @@keyframes pageIn { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }

    /* Hero */
    .ms-hero { background:linear-gradient(135deg,#0ea5e9 0%,#10b981 100%); border-radius:24px; padding:36px 40px; color:white; margin-bottom:24px; box-shadow:0 16px 40px rgba(14,165,233,0.2); display:flex; justify-content:space-between; align-items:center; position:relative; overflow:hidden; }
    .ms-hero::after { content:''; position:absolute; width:260px; height:260px; background:rgba(255,255,255,0.08); border-radius:50%; top:-130px; right:-80px; }
    .ms-hero .label { font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; opacity:0.7; }
    .ms-hero .amount { font-size:2.5rem; font-weight:800; letter-spacing:-0.04em; margin-top:6px; }
    .ms-hero .badge-pill { display:inline-flex; align-items:center; gap:6px; background:rgba(255,255,255,0.15); padding:6px 16px; border-radius:20px; font-size:0.78rem; font-weight:600; margin-top:12px; }

    /* Filter */
    .ms-filter { background:var(--card); border:1px solid var(--border); border-radius:18px; padding:22px 28px; margin-bottom:24px; box-shadow:0 4px 16px rgba(0,0,0,0.04); }
    .filter-row { display:grid; grid-template-columns:5fr 4fr 3fr; gap:16px; align-items:end; }
    .filter-label { font-size:0.68rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--muted); margin-bottom:6px; display:block; }
    .filter-select { width:100%; background:var(--bg); border:1.5px solid var(--border); border-radius:12px; padding:11px 14px 11px 40px; font-weight:600; font-size:0.88rem; color:var(--text-main); appearance:none; outline:none; transition:all 0.22s; font-family:inherit; }
    .filter-select:focus { border-color:var(--accent); background:var(--card); box-shadow:0 0 0 4px rgba(14,165,233,0.1); }
    .btn-filter { display:inline-flex; align-items:center; justify-content:center; gap:8px; background:var(--accent); color:white; border:none; padding:12px 20px; border-radius:12px; font-weight:700; font-size:0.88rem; width:100%; transition:all 0.22s; cursor:pointer; box-shadow:0 4px 14px rgba(14,165,233,0.2); font-family:inherit; }
    .btn-filter:hover { background:var(--accent-hover); transform:translateY(-1px); box-shadow:0 8px 22px rgba(14,165,233,0.3); }

    /* Table card */
    .ms-table-card { background:var(--card); border:1px solid var(--border); border-radius:20px; padding:24px 28px; box-shadow:0 4px 16px rgba(0,0,0,0.04); }
    .ms-table { width:100%; border-collapse:separate; border-spacing:0; margin-bottom:0; }
    .ms-table thead th { background:var(--bg); padding:14px 20px; font-size:0.7rem; font-weight:800; text-transform:uppercase; letter-spacing:0.08em; color:var(--muted); border:none; }
    .ms-table thead th:first-child { border-radius:10px 0 0 10px; }
    .ms-table thead th:last-child { border-radius:0 10px 10px 0; }
    .ms-table tbody td { padding:18px 20px; border-bottom:1px solid var(--border); vertical-align:middle; }
    .ms-table tbody tr:last-child td { border-bottom:none; }
    .ms-table .cat-name { font-weight:700; font-size:0.9rem; color:var(--text-main); }
    .ms-table .amount-cell { font-weight:800; font-size:0.92rem; color:var(--text-main); text-align:right; }
    .ms-table .total-row { background:var(--bg); }
    .ms-table .total-row td { padding:16px 20px; font-weight:800; border-bottom:none; }
    .ms-table .total-row td:first-child { border-radius:0 0 0 12px; }
    .ms-table .total-row td:last-child { border-radius:0 0 12px 0; }

    /* Progress */
    .prog-row { display:flex; align-items:center; gap:14px; }
    .prog-track { height:8px; background:var(--border); border-radius:8px; flex:1; overflow:hidden; }
    .prog-fill { height:100%; background:linear-gradient(90deg,var(--accent) 0%,#10b981 100%); border-radius:8px; transition:width 1s cubic-bezier(0.17,0.67,0.83,0.67); }
    .prog-pct { font-size:0.78rem; font-weight:700; color:var(--muted); min-width:36px; text-align:right; }

    @@media (max-width:767.98px) {
        .ms-hero { padding:24px 20px; border-radius:18px; flex-direction:column; align-items:flex-start; gap:12px; }
        .ms-hero .amount { font-size:2rem; }
        .filter-row { grid-template-columns:1fr; gap:12px; }
        .ms-table-card { padding:16px 14px; border-radius:16px; }
        .ms-table thead th { padding:10px 14px; font-size:0.64rem; }
        .ms-table tbody td { padding:14px; }
        .ms-table .cat-name { font-size:0.84rem; }
        .ms-table .amount-cell { font-size:0.86rem; }
    }
</style>

<div class="ms-page">
    <div class="d-flex justify-content-between align-items-center mb-4" style="gap:16px;flex-wrap:wrap">
        <div>
            <h1 style="font-size:1.35rem;font-weight:800;color:var(--text-main);margin:0">Monthly Report</h1>
            <p style="font-size:0.84rem;color:var(--muted);margin:4px 0 0">In-depth analysis for @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(selectedMonth) @selectedYear</p>
        </div>
    </div>

    <!-- Hero -->
    <div class="ms-hero">
        <div>
            <span class="label">Monthly Total Expenditure</span>
            <div class="amount">₹@grandTotal.ToString("N2")</div>
            <span class="badge-pill"><i data-lucide="calendar-days" style="width:14px;height:14px"></i> @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(selectedMonth) Statement</span>
        </div>
        <div class="d-none d-md-block"><i data-lucide="pie-chart" style="width:72px;height:72px;opacity:0.25"></i></div>
    </div>

    <!-- Filter -->
    <div class="ms-filter">
        <form method="get" asp-action="MonthlySummary">
            <div class="filter-row">
                <div>
                    <label class="filter-label">Statement Month</label>
                    <div class="position-relative">
                        <i data-lucide="calendar" class="position-absolute translate-middle-y top-50 start-0 ms-3 text-muted" style="width:16px;height:16px"></i>
                        <select name="month" class="filter-select">
                            @for (int m = 1; m <= 12; m++)
                            {
                                <option value="@m" selected="@(m == selectedMonth)">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                            }
                        </select>
                    </div>
                </div>
                <div>
                    <label class="filter-label">Accounting Year</label>
                    <div class="position-relative">
                        <i data-lucide="hash" class="position-absolute translate-middle-y top-50 start-0 ms-3 text-muted" style="width:16px;height:16px"></i>
                        <select name="year" class="filter-select">
                            @for (int y = DateTime.Now.Year - 5; y <= DateTime.Now.Year + 1; y++)
                            {
                                <option value="@y" selected="@(y == selectedYear)">@y</option>
                            }
                        </select>
                    </div>
                </div>
                <div>
                    <button type="submit" class="btn-filter"><i data-lucide="refresh-cw" style="width:15px;height:15px"></i> Update View</button>
                </div>
            </div>
        </form>
    </div>

    <!-- Data Table -->
    <div class="ms-table-card">
        <div class="d-flex justify-content-between align-items-center mb-3" style="flex-wrap:wrap;gap:8px">
            <h5 style="font-size:1rem;font-weight:800;color:var(--text-main);margin:0">Spending Distribution</h5>
            <span style="font-size:0.78rem;color:var(--muted);font-weight:600">@Model.Count() Categories</span>
        </div>

        <div class="table-responsive">
            <table class="ms-table">
                <thead>
                    <tr>
                        <th style="width:35%">Category</th>
                        <th style="width:40%">Usage</th>
                        <th style="text-align:right">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" style="text-align:center;padding:40px 16px">
                                <i data-lucide="layers" style="width:36px;height:36px;color:var(--border)" class="mb-2"></i><br>
                                <span style="font-weight:700;color:var(--text-main)">No Data Available</span><br>
                                <span style="font-size:0.82rem;color:var(--muted)">Try selecting a different month or year.</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var percent = grandTotal > 0 ? (int)((item.TotalAmount / grandTotal) * 100) : 0;
                            <tr>
                                <td><span class="cat-name">@item.CategoryName</span></td>
                                <td>
                                    <div class="prog-row">
                                        <div class="prog-track"><div class="prog-fill" style="width:0%" data-width="@percent%"></div></div>
                                        <span class="prog-pct">@percent%</span>
                                    </div>
                                </td>
                                <td class="amount-cell">₹@item.TotalAmount.ToString("N2")</td>
                            </tr>
                        }
                        <tr class="total-row">
                            <td style="font-size:0.78rem;text-transform:uppercase;color:var(--muted);font-weight:800">Total Monthly Expense</td>
                            <td></td>
                            <td style="text-align:right;font-size:1.1rem;font-weight:800;color:var(--accent)">₹@grandTotal.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            lucide.createIcons();
            setTimeout(() => { $('.prog-fill').each(function(){ $(this).css('width', $(this).data('width')); }); }, 300);
        });
    </script>
}
