@model ExpenseTracker.Models.Entities.Expense

@{
    ViewData["Title"] = "Add Transaction";
}

<style>
    :root { --accent:#0ea5e9; --accent-hover:#0284c7; --accent-soft:rgba(14,165,233,0.08); }
    .form-page { animation:slideIn 0.45s ease-out; }
    @@keyframes slideIn { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }

    .form-card { background:var(--card); border:1px solid var(--border); border-radius:20px; overflow:hidden; box-shadow:0 8px 30px rgba(0,0,0,0.06); }
    .form-card-header { padding:28px 32px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:16px; }
    .form-header-icon { width:50px; height:50px; border-radius:16px; flex-shrink:0; background:var(--accent-soft); color:var(--accent); display:flex; align-items:center; justify-content:center; }
    .form-card-header h2 { font-size:1.15rem; font-weight:800; color:var(--text-main); margin:0; }
    .form-card-header p { font-size:0.8rem; color:var(--muted); margin:3px 0 0; }
    .form-card-body { padding:28px 32px 32px; }

    /* AI Scan button */
    .btn-scan { display:inline-flex; align-items:center; gap:6px; background:var(--bg); border:1px solid var(--border); color:var(--text-main); padding:8px 16px; border-radius:10px; font-weight:700; font-size:0.76rem; cursor:pointer; transition:all 0.22s; margin-left:auto; }
    .btn-scan:hover { border-color:var(--accent); color:var(--accent); background:var(--accent-soft); }

    /* Fields */
    .field-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:20px; }
    .field-full { grid-column:1/-1; }
    .field-group { margin-bottom:20px; }
    .field-label { font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--muted); margin-bottom:7px; display:block; }
    .input-wrap { display:flex; align-items:stretch; border:1.5px solid var(--border); border-radius:14px; background:var(--bg); transition:all 0.22s; overflow:hidden; }
    .input-wrap:focus-within { border-color:var(--accent); background:var(--card); box-shadow:0 0 0 4px rgba(14,165,233,0.1); }
    .input-wrap-icon { width:46px; min-width:46px; display:flex; align-items:center; justify-content:center; color:var(--muted); flex-shrink:0; border-right:1.5px solid var(--border); transition:all 0.22s; }
    .input-wrap:focus-within .input-wrap-icon { color:var(--accent); border-right-color:var(--accent); }
    .input-wrap input, .input-wrap select, .input-wrap textarea { flex:1; border:none; background:transparent; outline:none; padding:12px 14px; font-size:0.9rem; font-weight:500; color:var(--text-main); min-width:0; appearance:none; font-family:inherit; }
    .input-wrap select { cursor:pointer; }
    .input-wrap textarea { resize:none; min-height:90px; }
    .input-wrap input::placeholder, .input-wrap textarea::placeholder { color:var(--muted); opacity:0.5; }

    /* Amount special */
    .amount-wrap { display:flex; align-items:stretch; border:1.5px solid var(--border); border-radius:14px; background:var(--bg); transition:all 0.22s; overflow:hidden; }
    .amount-wrap:focus-within { border-color:var(--accent); background:var(--card); box-shadow:0 0 0 4px rgba(14,165,233,0.1); }
    .currency-prefix { width:46px; min-width:46px; display:flex; align-items:center; justify-content:center; font-weight:800; color:var(--muted); font-size:1.1rem; border-right:1.5px solid var(--border); flex-shrink:0; transition:all 0.22s; }
    .amount-wrap:focus-within .currency-prefix { color:var(--accent); border-right-color:var(--accent); }
    .amount-wrap input { flex:1; border:none; background:transparent; outline:none; padding:14px 16px; font-size:1.3rem; font-weight:800; color:var(--text-main); min-width:0; font-family:inherit; }
    .amount-wrap input::placeholder { color:var(--muted); opacity:0.4; }

    /* Buttons */
    .btn-submit { display:inline-flex; align-items:center; justify-content:center; gap:8px; background:var(--accent); color:white; border:none; padding:13px 28px; border-radius:12px; font-weight:700; font-size:0.9rem; transition:all 0.22s; box-shadow:0 4px 16px rgba(14,165,233,0.2); cursor:pointer; }
    .btn-submit:hover { background:var(--accent-hover); transform:translateY(-1px); box-shadow:0 8px 24px rgba(14,165,233,0.3); }
    .btn-back-link { display:inline-flex; align-items:center; gap:6px; color:var(--muted); font-weight:600; font-size:0.88rem; text-decoration:none; transition:all 0.2s; }
    .btn-back-link:hover { color:var(--text-main); }
    .form-actions { display:flex; justify-content:space-between; align-items:center; margin-top:28px; }

    @@media (max-width:767.98px) {
        .form-card { border-radius:18px; }
        .form-card-header { padding:20px 18px; gap:12px; flex-wrap:wrap; }
        .form-header-icon { width:44px; height:44px; border-radius:12px; }
        .form-header-icon svg { width:22px; height:22px; }
        .form-card-header h2 { font-size:1.05rem; }
        .form-card-body { padding:20px 18px 26px; }
        .field-row { grid-template-columns:1fr; gap:0; }
        .field-group { margin-bottom:16px; }
        .field-label { font-size:0.66rem; margin-bottom:5px; }
        .input-wrap { border-radius:12px; }
        .input-wrap-icon { width:42px; min-width:42px; }
        .input-wrap-icon svg { width:16px; height:16px; }
        .input-wrap input, .input-wrap select, .input-wrap textarea { padding:11px 12px; font-size:0.86rem; }
        .amount-wrap { border-radius:12px; }
        .currency-prefix { width:42px; min-width:42px; font-size:1rem; }
        .amount-wrap input { padding:12px 14px; font-size:1.15rem; }
        .form-actions { flex-direction:column-reverse; gap:12px; align-items:stretch; }
        .btn-submit { width:100%; padding:14px 20px; }
        .btn-back-link { justify-content:center; padding:8px 0; }
        .btn-scan { margin-left:0; margin-top:8px; }
    }
</style>

<div class="form-page">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-header-icon">
                        <i data-lucide="receipt" style="width:24px;height:24px"></i>
                    </div>
                    <div style="flex:1">
                        <h2>Record Expense</h2>
                        <p>Keep track of your spending to reach your financial goals.</p>
                    </div>
                    <button type="button" id="scanReceiptBtn" class="btn-scan">
                        <i data-lucide="scan" style="width:14px;height:14px"></i> AI Scan
                    </button>
                    <input type="file" id="receiptUpload" class="d-none" accept="image/*" />
                </div>

                <div class="form-card-body">
                    <form asp-action="Create" method="post">
                        <div class="field-row">
                            <div>
                                <label asp-for="ExpenseDate" class="field-label">Transaction Date</label>
                                <div class="input-wrap">
                                    <div class="input-wrap-icon"><i data-lucide="calendar" style="width:17px;height:17px"></i></div>
                                    <input asp-for="ExpenseDate" type="date" value='@DateTime.Today.ToString("yyyy-MM-dd")' max='@DateTime.Today.ToString("yyyy-MM-dd")' />
                                </div>
                                <span asp-validation-for="ExpenseDate" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div>
                                <label asp-for="CategoryId" class="field-label">Category</label>
                                <div class="input-wrap">
                                    <div class="input-wrap-icon"><i data-lucide="tag" style="width:17px;height:17px"></i></div>
                                    <select asp-for="CategoryId" asp-items="ViewBag.CategoryList">
                                        <option value="">-- Category --</option>
                                    </select>
                                </div>
                                <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="field-group">
                            <label asp-for="AccountId" class="field-label">Payment Account / Wallet</label>
                            <div class="input-wrap">
                                <div class="input-wrap-icon"><i data-lucide="wallet" style="width:17px;height:17px"></i></div>
                                <select asp-for="AccountId" asp-items="ViewBag.AccountList">
                                    <option value="">-- Select Account --</option>
                                </select>
                            </div>
                            <span asp-validation-for="AccountId" class="text-danger small mt-1 d-block"></span>
                            <!-- Hidden field containing cash account IDs for client-side filtering -->
                            <input type="hidden" id="cashAccountIds" value="@string.Join(",", (ViewBag.CashAccountIds as IEnumerable<int> ?? new List<int>()))" />
                        </div>

                        <div class="field-group">
                            <label asp-for="Amount" class="field-label">Amount Spent</label>
                            <div class="amount-wrap">
                                <span class="currency-prefix">₹</span>
                                <input asp-for="Amount" class="amount-field" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Amount" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="field-group">
                            <label asp-for="Description" class="field-label">Notes (Optional)</label>
                            <div class="input-wrap">
                                <div class="input-wrap-icon" style="align-items:flex-start;padding-top:14px"><i data-lucide="file-text" style="width:17px;height:17px"></i></div>
                                <textarea asp-for="Description" placeholder="What was this expense for?"></textarea>
                            </div>
                            <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="form-actions">
                            <a asp-action="Index" class="btn-back-link">
                                <i data-lucide="arrow-left" style="width:16px;height:16px"></i> Back to history
                            </a>
                            <button type="submit" class="btn-submit">
                                <i data-lucide="check" style="width:16px;height:16px"></i> Save Transaction
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            lucide.createIcons();
            $('#scanReceiptBtn').on('click', function() { $('#receiptUpload').click(); });
            $('#receiptUpload').on('change', function() {
                if (this.files && this.files[0]) {
                    const btn = $('#scanReceiptBtn');
                    const originalHtml = btn.html();
                    btn.html('<span class="spinner-border spinner-border-sm me-1"></span> Analyzing...').prop('disabled', true);
                    setTimeout(() => {
                        const simulatedResults = [
                            { amount: 1250.50, category: 1, desc: "Starbucks Coffee & Snacks" },
                            { amount: 450.00, category: 2, desc: "Uber Ride - Business Trip" },
                            { amount: 89.99, category: 3, desc: "Grocery Shopping - Walmart" }
                        ];
                        const result = simulatedResults[Math.floor(Math.random() * simulatedResults.length)];
                        $('.amount-field').val(result.amount).addClass('is-valid');
                        $('select[name="CategoryId"]').val(result.category).addClass('is-valid');
                        $('textarea[name="Description"]').val(result.desc).addClass('is-valid');
                        btn.html('<i data-lucide="check-circle" style="width:14px;height:14px"></i> Done').css({borderColor:'#22c55e',color:'#22c55e'});
                        setTimeout(() => { btn.html(originalHtml).css({borderColor:'',color:''}).prop('disabled', false); lucide.createIcons(); }, 2000);
                        Toast.fire({ icon:'success', title:'AI Analysis complete!', text:'Form pre-filled based on receipt data.' });
                    }, 2000);
                }
            });
        });
    </script>
    <script>
        $(function(){
            const cashIds = $('#cashAccountIds').val().split(',').map(id=>id.trim()).filter(id=>id);
            $('#CategoryId').on('change', function(){
                const selectedCat = $(this).find('option:selected').text().trim();
                $('#AccountId option').prop('disabled', false);
                if(selectedCat === 'To Cash'){
                    cashIds.forEach(id => {
                        $('#AccountId option[value="' + id + '"]').prop('disabled', true);
                    });
                    if(cashIds.includes($('#AccountId').val())){
                        $('#AccountId').val('');
                    }
                }
            });
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
