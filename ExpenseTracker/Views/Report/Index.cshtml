@{
    ViewData["Title"] = "Financial Reports";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-800 text-main-adaptive mb-1">Financial Analysis & Reports</h2>
            <p class="text-muted">Generate detailed summaries and export your data.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="glass-card p-4 h-100">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="icon-box bg-primary text-white p-3 rounded-4">
                        <i data-lucide="file-text"></i>
                    </div>
                    <div>
                        <h5 class="fw-700 mb-0">Custom Period Report</h5>
                        <small class="text-muted">Detailed transaction list with category breakdown</small>
                    </div>
                </div>

                <form asp-action="GetFullReport" method="get">
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-600 small text-muted text-uppercase">Start Date</label>
                            <input type="date" name="startDate" class="form-control rounded-3" value="@DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600 small text-muted text-uppercase">End Date</label>
                            <input type="date" name="endDate" class="form-control rounded-3" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-700 shadow-sm">
                        Generate Report
                    </button>
                </form>
            </div>
        </div>

        <div class="col-md-6">
            <div class="glass-card p-4 h-100 bg-dark text-white border-0">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="icon-box bg-warning text-main-adaptive p-3 rounded-4">
                        <i data-lucide="zap"></i>
                    </div>
                    <div>
                        <h5 class="fw-700 mb-0">Quick Export</h5>
                        <small class="text-secondary">One-click downloads for current month</small>
                    </div>
                </div>

                <div class="d-grid gap-3">
                    <a asp-action="GetFullReport" asp-route-startDate="@(new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1).ToString("yyyy-MM-dd"))" class="btn btn-outline-light py-3 rounded-3 fw-600 d-flex align-items-center justify-content-center gap-2">
                        <i data-lucide="download" size="18"></i> Current Month Summary
                    </a>
                    <a href="#" onclick="Toast.fire({ icon: 'info', title: 'Excel export coming soon!' })" class="btn btn-outline-light py-3 rounded-3 fw-600 d-flex align-items-center justify-content-center gap-2">
                        <i data-lucide="file-spreadsheet" size="18"></i> Export to Excel
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

