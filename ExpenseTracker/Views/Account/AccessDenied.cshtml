@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Access Denied - ExpensePro</title>
    <link rel="icon" type="image/x-icon" href="~/favicon1.ico" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--bg);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .error-card {
            text-align: center;
            background: var(--card);
            padding: 50px;
            border-radius: 32px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
            max-width: 500px;
        }
        .icon-circle {
            width: 80px;
            height: 80px;
            background: var(--card);
            color: #ef4444;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 30px;
        }
    </style>
</head>
<body>
    <div class="error-card">
        <div class="icon-circle">
            <i data-lucide="shield-off" size="40"></i>
        </div>
        <h2 class="fw-800 text-main-adaptive mb-3">Access Denied</h2>
        <p class="text-muted mb-4">You do not have permission to access this resource. Please contact your administrator if you believe this is an error.</p>
        <a href="/" class="btn btn-primary rounded-pill px-5 py-3 fw-700">Go to Dashboard</a>
    </div>
    <script>lucide.createIcons();</script>
</body>
</html>

